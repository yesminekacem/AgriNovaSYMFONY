{% extends 'baseBack.html.twig' %}

{% block title %}Admin Dashboard – AGRINOVA{% endblock %}
{% block page_title %}Dashboard{% endblock %}

{% block body %}
<style>
    :root {
        --green-dark: #1a4d2e;
        --green-mid: #2d7a45;
        --green-soft: #d9e8dd;
        --green-bg: #edf5ef;
        --text-dark: #101828;
        --text-mid: #5f6f64;
        --border: #d8e4da;
        --orange: #f59e0b;
        --white: #ffffff;
        --shadow-sm: 0 2px 8px rgba(0,0,0,0.05);
        --shadow-md: 0 8px 24px rgba(0,0,0,0.06);
    }

    .dashboard-page {
        padding: 2rem;
        background: #f6faf7;
        min-height: 100vh;
        font-family: 'DM Sans', sans-serif;
    }

    .hero-banner {
        position: relative;
        overflow: hidden;
        border-radius: 24px;
        min-height: 280px;
        padding: 2.5rem;
        color: white;
        display: flex;
        align-items: center;
        background:
            linear-gradient(90deg, rgba(26,77,46,0.72), rgba(45,122,69,0.35), rgba(245,158,11,0.45)),
            url('{{ asset("Front/images/Forum/dashboard-banner.jpg") }}') center/cover no-repeat;
        box-shadow: var(--shadow-md);
        margin-bottom: 1.8rem;
    }

    .hero-content {
        max-width: 760px;
        z-index: 2;
    }

    .hero-title {
        font-size: 3rem;
        line-height: 1.1;
        font-weight: 800;
        margin-bottom: 1rem;
        letter-spacing: -0.03em;
    }

    .hero-text {
        font-size: 1.1rem;
        line-height: 1.65;
        max-width: 760px;
        color: rgba(255,255,255,0.95);
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.3rem;
        margin-bottom: 1.8rem;
    }

    .stat-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 1.8rem;
        box-shadow: var(--shadow-sm);
        display: flex;
        justify-content: space-between;
        align-items: center;
        min-height: 150px;
    }

    .stat-label {
        color: #6b7f71;
        font-size: 0.95rem;
        margin-bottom: 0.7rem;
        font-weight: 500;
    }

    .stat-value {
        font-size: 2.2rem;
        font-weight: 800;
        color: var(--text-dark);
        line-height: 1;
        margin-bottom: 0.6rem;
    }

    .stat-change {
        color: #16a34a;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .stat-icon {
        width: 62px;
        height: 62px;
        border-radius: 18px;
        background: #dcebe0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--green-mid);
        flex-shrink: 0;
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.6rem;
    }

    .panel {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 22px;
        padding: 1.9rem;
        box-shadow: var(--shadow-sm);
    }

    .panel-title {
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--text-dark);
        margin-bottom: 1.6rem;
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .panel-title .green-icon { color: var(--green-mid); }
    .panel-title .orange-icon { color: var(--orange); }

    .yield-item {
        margin-bottom: 1.45rem;
    }

    .yield-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.55rem;
        font-size: 0.98rem;
    }

    .yield-name {
        color: var(--text-dark);
        font-weight: 500;
    }

    .yield-value {
        color: #57715f;
        font-weight: 600;
    }

    .progress-track {
        width: 100%;
        height: 10px;
        background: #dfe7e1;
        border-radius: 999px;
        overflow: hidden;
    }

    .progress-fill {
        height: 100%;
        border-radius: 999px;
    }

    .progress-fill.green { background: #2f9e4f; }
    .progress-fill.orange { background: #f59e0b; }

    .transaction-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .transaction-item {
        background: #f7faf7;
        border-radius: 16px;
        padding: 1rem 1rem 0.95rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .transaction-name {
        font-size: 0.98rem;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 0.25rem;
    }

    .transaction-desc {
        color: #6b7f71;
        font-size: 0.92rem;
    }

    .transaction-price {
        color: #16a34a;
        font-size: 1rem;
        font-weight: 800;
        text-align: right;
        margin-bottom: 0.25rem;
    }

    .transaction-time {
        color: #6b7f71;
        font-size: 0.9rem;
        text-align: right;
    }

    @media (max-width: 1100px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .dashboard-grid {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 700px) {
        .dashboard-page {
            padding: 1rem;
        }

        .hero-banner {
            padding: 1.5rem;
            min-height: 220px;
        }

        .hero-title {
            font-size: 2rem;
        }

        .stats-grid {
            grid-template-columns: 1fr;
        }

        .stat-card {
            min-height: auto;
        }
    }

    .summary-grid {
        display: grid;
        grid-template-columns: 1fr minmax(320px, 1.2fr);
        gap: 1.6rem;
        margin-top: 1.8rem;
    }

    .summary-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 0;
        border-bottom: 1px solid var(--border);
        gap: 1rem;
    }

    .summary-item:last-child {
        border-bottom: none;
    }

    .summary-label {
        color: var(--text-mid);
        font-weight: 600;
    }

    .summary-value {
        color: var(--text-dark);
        font-weight: 700;
        font-size: 1.2rem;
    }

    .chart-wrapper {
        min-height: 360px;
        display: grid;
        place-items: center;
    }

    .chart-card {
        width: 100%;
    }

    .chart-footer {
        margin-top: 1.1rem;
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .chart-pill {
        background: #f3f8f4;
        border-radius: 999px;
        padding: 0.65rem 1rem;
        color: #2d7a45;
        font-size: 0.94rem;
        font-weight: 600;
    }
</style>

<div class="dashboard-page">

    <section class="hero-banner">
        <div class="hero-content">
            <h1 class="hero-title">Welcome to AGRINOVA</h1>
            <p class="hero-text">
                Your smart farm management and marketplace platform.
                Monitor crops, manage inventory, and connect with buyers.
            </p>
        </div>
    </section>

    <section class="stats-grid">
        {% for stat in stats %}
            <div class="stat-card">
                <div>
                    <div class="stat-label">{{ stat.label }}</div>
                    <div class="stat-value">{{ stat.value }}</div>
                    <div class="stat-change">{{ stat.change }}</div>
                </div>

                <div class="stat-icon">
                    {% if stat.icon == 'users' %}
                        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                            <circle cx="8.5" cy="7" r="4"/>
                            <path d="M20 8v6"/>
                            <path d="M23 11h-6"/>
                        </svg>
                    {% elseif stat.icon == 'cart' %}
                        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <circle cx="9" cy="21" r="1"/>
                            <circle cx="20" cy="21" r="1"/>
                            <path d="M1 1h4l2.68 13.39A2 2 0 0 0 9.64 16H19a2 2 0 0 0 2-1.61L23 6H6"/>
                        </svg>
                    {% elseif stat.icon == 'box' %}
                        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                            <path d="M3.3 7l8.7 5 8.7-5"/>
                            <path d="M12 22V12"/>
                        </svg>
                    {% elseif stat.icon == 'leaf' %}
                        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M11 20A7 7 0 0 1 4 13C4 8 8 4 13 4c4 0 7 3 7 7 0 5-4 9-9 9Z"/>
                            <path d="M12 20V10"/>
                            <path d="M8 14c2 0 4-2 4-4"/>
                        </svg>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </section>

    <section class="dashboard-grid">
        <div class="panel">
            <div class="panel-title">
                <span class="green-icon">↗</span>
                <span>Crop Yield Overview</span>
            </div>

            {% for crop in cropYields %}
                <div class="yield-item">
                    <div class="yield-row">
                        <span class="yield-name">{{ crop.name }}</span>
                        <span class="yield-value">{{ crop.value }}%</span>
                    </div>
                    <div class="progress-track">
                        <div class="progress-fill {{ crop.color }}" style="width: {{ crop.value }}%;"></div>
                    </div>
                </div>
            {% endfor %}
        </div>
<div class="panel">
    <div class="panel-title">
        <span class="orange-icon">📊</span>
        <span>Forum Category Statistics</span>
    </div>

    {% for category in categoryStats %}
        <div class="yield-item">
            <div class="yield-row">
                <span class="yield-name">{{ category.name }}</span>
                <span class="yield-value">{{ category.count }} posts</span>
            </div>
            <div class="progress-track">
                <div class="progress-fill {{ category.color }}"
                     style="width: {{ totalPosts > 0 ? (category.count / totalPosts * 100) : 0 }}%;"></div>
            </div>
        </div>
    {% endfor %}
</div>
    </section>

    <section class="summary-grid">
        <div class="panel">
            <div class="panel-title">
                <span class="green-icon">📦</span>
                <span>Inventory & Rental Snapshot</span>
            </div>

            <div class="summary-item">
                <span class="summary-label">Total inventory items</span>
                <span class="summary-value">{{ inventoryStats.total }}</span>
            </div>
            <div class="summary-item">
                <span class="summary-label">Rentable inventory</span>
                <span class="summary-value">{{ inventoryStats.rentable }}</span>
            </div>
            <div class="summary-item">
                <span class="summary-label">Currently rented out</span>
                <span class="summary-value">{{ inventoryStats.rentedOut }}</span>
            </div>
            <div class="summary-item">
                <span class="summary-label">Low-stock items</span>
                <span class="summary-value">{{ inventoryStats.lowStock }}</span>
            </div>

            <div class="summary-item">
                <span class="summary-label">Total rental agreements</span>
                <span class="summary-value">{{ rentalStats.total }}</span>
            </div>
            <div class="summary-item">
                <span class="summary-label">Active rentals</span>
                <span class="summary-value">{{ rentalStats.active }}</span>
            </div>
            <div class="summary-item">
                <span class="summary-label">Pending rentals</span>
                <span class="summary-value">{{ rentalStats.pending }}</span>
            </div>
            <div class="summary-item">
                <span class="summary-label">Overdue rentals</span>
                <span class="summary-value">{{ rentalStats.overdue }}</span>
            </div>
        </div>

        <div class="panel chart-card">
            <div class="panel-title">
                <span class="orange-icon">📈</span>
                <span>Inventory + Rental Live Chart</span>
            </div>

            <div class="chart-wrapper">
                <canvas id="inventoryRentalChart"
                    data-inventory-labels='{{ inventoryChartData.labels|json_encode|raw }}'
                    data-inventory-values='{{ inventoryChartData.values|json_encode|raw }}'
                    data-rental-labels='{{ rentalChartData.labels|json_encode|raw }}'
                    data-rental-values='{{ rentalChartData.values|json_encode|raw }}'>
                </canvas>
            </div>

            <div class="chart-footer">
                <span class="chart-pill">Inventory available: {{ inventoryChartData.values[0] }}</span>
                <span class="chart-pill">Rentable: {{ inventoryChartData.values[1] }}</span>
                <span class="chart-pill">Rented out: {{ inventoryChartData.values[2] }}</span>
                <span class="chart-pill">Overdue rentals: {{ rentalStats.overdue }}</span>
            </div>
        </div>
    </section>

</div>

{% endblock %}

{% block javascripts %}
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const chartEl = document.getElementById('inventoryRentalChart');
            if (!chartEl) return;

            const inventoryLabels = JSON.parse(chartEl.dataset.inventoryLabels);
            const inventoryValues = JSON.parse(chartEl.dataset.inventoryValues);
            const rentalLabels = JSON.parse(chartEl.dataset.rentalLabels);
            const rentalValues = JSON.parse(chartEl.dataset.rentalValues);

            new Chart(chartEl.getContext('2d'), {
                type: 'bar',
                data: {
                    labels: inventoryLabels.concat(rentalLabels),
                    datasets: [
                        {
                            label: 'Inventory counts',
                            data: inventoryValues.concat(new Array(rentalLabels.length).fill(null)),
                            backgroundColor: 'rgba(45, 122, 69, 0.78)',
                            borderColor: 'rgba(45, 122, 69, 1)',
                            borderWidth: 1,
                        },
                        {
                            label: 'Rental status',
                            data: new Array(inventoryLabels.length).fill(null).concat(rentalValues),
                            backgroundColor: 'rgba(245, 158, 11, 0.78)',
                            borderColor: 'rgba(245, 158, 11, 1)',
                            borderWidth: 1,
                        },
                    ],
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: {
                            stacked: false,
                            ticks: {
                                color: '#394047',
                                font: { weight: '600' }
                            },
                            grid: { display: false }
                        },
                        y: {
                            beginAtZero: true,
                            ticks: {
                                color: '#4b5563'
                            },
                            grid: {
                                color: 'rgba(148, 163, 184, 0.18)'
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            position: 'top',
                            labels: {
                                color: '#374151',
                                boxWidth: 12,
                                padding: 16
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return context.dataset.label + ': ' + context.parsed.y;
                                }
                            }
                        }
                    }
                }
            });
        });
    </script>
{% endblock %}