{% extends 'baseBack.html.twig' %}

{% block title %}All Products - Admin{% endblock %}
{% block page_title %}Marketplace › Products{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('Front/css/admin.css') }}">
{% endblock %}

{% block body %}
<div class="card admin-card" style="max-width:1300px;margin:1rem auto;padding:1.25rem;border-radius:10px;background:#fff;">

    {# ── Nav ── #}
    {% set current_route = app.request.attributes.get('_route') %}
    <div class="mb-8">
        <nav class="flex space-x-1 bg-white rounded-xl p-1 border border-slate-200 shadow-sm">

            <a href="{{ path('admin_marketplace_products') }}"
               class="flex-1 px-4 py-3 text-sm font-medium rounded-lg transition-all duration-200 text-center
               {% if current_route starts with 'admin_marketplace_product' %}
                   bg-green-600 text-white shadow-sm
               {% else %}
                   text-slate-600 hover:text-slate-900 hover:bg-slate-50
               {% endif %}">
                <svg class="w-4 h-4 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                Manage Products
            </a>

            <a href="{{ path('admin_marketplace_orders') }}"
               class="flex-1 px-4 py-3 text-sm font-medium rounded-lg transition-all duration-200 text-center
               {% if current_route starts with 'admin_marketplace_order' %}
                   bg-green-600 text-white shadow-sm
               {% else %}
                   text-slate-600 hover:text-slate-900 hover:bg-slate-50
               {% endif %}">
                <svg class="w-4 h-4 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
                </svg>
                Orders
            </a>

        </nav>
    </div>

    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
        <h1 style="font-size:1.3rem;font-weight:700;color:#1a2e1a;margin:0;">All Products</h1>
        <div class="flex items-center gap-3">
            <!-- Category Filter -->
            <div class="relative">
                <select id="category-filter" class="appearance-none block pl-4 pr-10 py-3 text-sm text-gray-900 border border-slate-300 rounded-lg bg-gray-50 focus:ring-green-500 focus:border-green-500 cursor-pointer">
                    <option value="" {% if not currentCategory %}selected{% endif %}>All Categories</option>
                    <option value="Vegetables" {% if currentCategory == 'Vegetables' %}selected{% endif %}>Vegetables</option>
                    <option value="Fruits" {% if currentCategory == 'Fruits' %}selected{% endif %}>Fruits</option>
                    <option value="Grains" {% if currentCategory == 'Grains' %}selected{% endif %}>Grains</option>
                </select>
                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                    <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </div>
            </div>

            <a href="{{ path('admin_marketplace_product_create') }}" class="inline-flex items-center rounded-xl bg-green-700 px-5 py-3 text-sm font-semibold text-white transition hover:bg-green-800">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mr-2">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Create Product
        </a>
        </div>
    </div>

    {% for flash in app.flashes('error') %}
        <div class="alert alert-error">{{ flash }}</div>
    {% endfor %}
    {% for flash in app.flashes('success') %}
        <div class="alert alert-success">{{ flash }}</div>
    {% endfor %}

    <div class="table-wrap" style="overflow:auto;">
    <table class="admin-table" style="width:100%;min-width:900px;border-collapse:collapse;">
        <thead>
            <tr>
                <th>ID</th>
                <th>Image</th>
                <th>Product Name</th>
                <th>Category</th>
                <th>Price (TND/kg)</th>
                <th>Qty (kg)</th>
                <th>Status</th>
                <th>Owner</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for product in products %}
            <tr>
                <td style="padding:10px 12px;border-bottom:1px solid #eef;">{{ product.listingId }}</td>
                <td style="padding:10px 12px;border-bottom:1px solid #eef;">
                    {% if product.picture %}
                        <img src="/uploads/products/{{ product.picture }}"
                             alt="{{ product.productName }}"
                             style="width:48px;height:48px;object-fit:cover;border-radius:6px;border:1px solid #e5e7eb;">
                    {% else %}
                        <div style="width:48px;height:48px;border-radius:6px;background:#f0fdf4;display:flex;align-items:center;justify-content:center;font-size:1.4rem;">🌾</div>
                    {% endif %}
                </td>
                <td style="padding:10px 12px;border-bottom:1px solid #eef;font-weight:600;">{{ product.productName }}</td>
                <td style="padding:10px 12px;border-bottom:1px solid #eef;">
                    <span style="display:inline-block;padding:2px 10px;border-radius:999px;font-size:.75rem;font-weight:600;
                        {% if product.category == 'Vegetables' %}background:#dcfce7;color:#15803d;
                        {% elseif product.category == 'Fruits' %}background:#fef9c3;color:#854d0e;
                        {% else %}background:#fef3c7;color:#92400e;{% endif %}">
                        {{ product.category }}
                    </span>
                </td>
                <td style="padding:10px 12px;border-bottom:1px solid #eef;">{{ product.pricePerUnit }}</td>
                <td style="padding:10px 12px;border-bottom:1px solid #eef;">{{ product.quantity }}</td>
                <td style="padding:10px 12px;border-bottom:1px solid #eef;">
                    <span style="display:inline-block;padding:2px 10px;border-radius:999px;font-size:.75rem;font-weight:600;
                        {% if product.status == 'available' %}background:#dcfce7;color:#15803d;
                        {% else %}background:#fee2e2;color:#991b1b;{% endif %}">
                        {{ product.status ?? '—' }}
                    </span>
                </td>
                <td style="padding:10px 12px;border-bottom:1px solid #eef;font-size:.82rem;color:#6b7280;">{{ product.userId }}</td>
                <td style="padding:8px 12px;border-bottom:1px solid #eef;">
                    <a href="{{ path('admin_marketplace_product_edit', {id: product.listingId}) }}"
                       class="inline-flex items-center rounded-lg bg-blue-600 px-3 py-2 text-xs font-semibold text-white transition hover:bg-blue-700 mr-2">Edit</a>

                    <form method="post"
                          action="{{ path('admin_marketplace_product_delete', {id: product.listingId}) }}"
                          style="display:inline-block;"
                          onsubmit="return confirm('Delete this product?')">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('delete_product_' ~ product.listingId) }}">
                        <button type="submit" class="inline-flex items-center rounded-lg bg-red-600 px-3 py-2 text-xs font-semibold text-white transition hover:bg-red-700">Delete</button>
                    </form>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="9" style="padding:2rem;text-align:center;color:#6b7280;">No products found.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
    document.getElementById('category-filter').addEventListener('change', function () {
        const url = new URL(window.location.href);
        if (this.value) {
            url.searchParams.set('category', this.value);
        } else {
            url.searchParams.delete('category');
        }
        window.location.href = url.toString();
    });
</script>
{% endblock %}
