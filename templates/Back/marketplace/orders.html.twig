{% extends 'baseBack.html.twig' %}

{% block title %}All Orders - Admin{% endblock %}
{% block page_title %}Marketplace › Orders{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('Front/css/admin.css') }}">
{% endblock %}

{% block body %}
<div class="card admin-card" style="max-width:1300px;margin:1rem auto;padding:1.25rem;border-radius:10px;background:#fff;">

    {# ── Nav ── #}
    {% set current_route = app.request.attributes.get('_route') %}
    <div class="mb-8">
        <nav class="flex space-x-1 bg-white rounded-xl p-1 border border-slate-200 shadow-sm">

            <a href="{{ path('admin_marketplace_products') }}"
               class="flex-1 px-4 py-3 text-sm font-medium rounded-lg transition-all duration-200 text-center
               {% if current_route starts with 'admin_marketplace_product' %}
                   bg-green-600 text-white shadow-sm
               {% else %}
                   text-slate-600 hover:text-slate-900 hover:bg-slate-50
               {% endif %}">
                <svg class="w-4 h-4 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                Manage Products
            </a>

            <a href="{{ path('admin_marketplace_orders') }}"
               class="flex-1 px-4 py-3 text-sm font-medium rounded-lg transition-all duration-200 text-center
               {% if current_route starts with 'admin_marketplace_order' %}
                   bg-green-600 text-white shadow-sm
               {% else %}
                   text-slate-600 hover:text-slate-900 hover:bg-slate-50
               {% endif %}">
                <svg class="w-4 h-4 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
                </svg>
                Orders
            </a>

        </nav>
    </div>

    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
        <h1 style="font-size:1.3rem;font-weight:700;color:#1a2e1a;margin:0;">All Orders</h1>

        <!-- Status Filter -->
        <div class="relative">
            <select id="status-filter" class="appearance-none block pl-4 pr-10 py-3 text-sm text-gray-900 border border-slate-300 rounded-lg bg-gray-50 focus:ring-green-500 focus:border-green-500 cursor-pointer">
                <option value="" {% if not currentStatus %}selected{% endif %}>All Statuses</option>
                <option value="Pending"   {% if currentStatus == 'Pending'   %}selected{% endif %}>Pending</option>
                <option value="Delivered" {% if currentStatus == 'Delivered' %}selected{% endif %}>Delivered</option>
                <option value="Cancelled" {% if currentStatus == 'Cancelled' %}selected{% endif %}>Cancelled</option>
            </select>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
            </div>
        </div>
    </div>

    {% for flash in app.flashes('error') %}
        <div class="alert alert-error">{{ flash }}</div>
    {% endfor %}
    {% for flash in app.flashes('success') %}
        <div class="alert alert-success">{{ flash }}</div>
    {% endfor %}

    <div class="table-wrap" style="overflow:auto;">
    <table class="admin-table" style="width:100%;min-width:1000px;border-collapse:collapse;">
        <thead>
            <tr>
                <th>ID</th>
                <th>Customer</th>
                <th>Date</th>
                <th>Total (TND)</th>
                <th>Status</th>
                <th>Payment</th>
                <th>Items</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for order in orders %}
            <tr>
                <td style="padding:10px 12px;border-bottom:1px solid #eef;font-weight:600;">#{{ order.id }}</td>
                <td style="padding:10px 12px;border-bottom:1px solid #eef;font-size:.82rem;color:#6b7280;">{{ order.userId }}</td>
                <td style="padding:10px 12px;border-bottom:1px solid #eef;font-size:.85rem;">
                    {{ order.orderDate ? order.orderDate|date('d M Y') : '—' }}
                </td>
                <td style="padding:10px 12px;border-bottom:1px solid #eef;font-weight:600;">{{ order.totalPrice }}</td>
                <td style="padding:10px 12px;border-bottom:1px solid #eef;">
                    <span style="display:inline-block;padding:3px 12px;border-radius:999px;font-size:.75rem;font-weight:600;
                        {% if order.status == 'Pending' %}background:#fef9c3;color:#854d0e;
                        {% elseif order.status == 'Confirmed' %}background:#dbeafe;color:#1e40af;
                        {% elseif order.status == 'Shipped' %}background:#f3e8ff;color:#6b21a8;
                        {% elseif order.status == 'Delivered' %}background:#dcfce7;color:#15803d;
                        {% elseif order.status == 'Cancelled' %}background:#fee2e2;color:#991b1b;
                        {% else %}background:#f1f5f9;color:#475569;{% endif %}">
                        {{ order.status ?? 'Unknown' }}
                    </span>
                </td>
                <td style="padding:10px 12px;border-bottom:1px solid #eef;font-size:.82rem;">{{ order.paymentMethod ?? '—' }}</td>
                <td style="padding:10px 12px;border-bottom:1px solid #eef;font-size:.82rem;">
                    {% if order.orderItems|length > 0 %}
                        <ul style="margin:0;padding:0;list-style:none;">
                            {% for item in order.orderItems %}
                                <li style="white-space:nowrap;">{{ item.productName }} × {{ item.quantity }}</li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        —
                    {% endif %}
                </td>
                <td style="padding:8px 12px;border-bottom:1px solid #eef;white-space:nowrap;">
                    {% if order.status != 'Delivered' %}
                        <form method="post"
                              action="{{ path('admin_marketplace_order_validate', {id: order.id}) }}"
                              style="display:inline-block;margin-right:6px;"
                              onsubmit="return confirm('Mark order #{{ order.id }} as Delivered?')">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('validate_order_' ~ order.id) }}">
                            <button type="submit" class="inline-flex items-center rounded-lg bg-green-600 px-3 py-2 text-xs font-semibold text-white transition hover:bg-green-700">Validate</button>
                        </form>
                    {% else %}
                        <span class="inline-flex items-center rounded-lg bg-green-100 px-3 py-2 text-xs font-semibold text-green-800 mr-2">✓ Delivered</span>
                    {% endif %}

                    <a href="{{ path('admin_marketplace_order_invoice', {id: order.id}) }}"
                       class="inline-flex items-center rounded-lg bg-slate-600 px-3 py-2 text-xs font-semibold text-white transition hover:bg-slate-700 mr-2">
                        <svg style="width:13px;height:13px;margin-right:4px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                        PDF
                    </a>

                    <form method="post"
                          action="{{ path('admin_marketplace_order_delete', {id: order.id}) }}"
                          style="display:inline-block;"
                          onsubmit="return confirm('Delete order #{{ order.id }}? This cannot be undone.')">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('delete_order_' ~ order.id) }}">
                        <button type="submit" class="inline-flex items-center rounded-lg bg-red-600 px-3 py-2 text-xs font-semibold text-white transition hover:bg-red-700">Delete</button>
                    </form>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8" style="padding:2rem;text-align:center;color:#6b7280;">No orders found.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
    document.getElementById('status-filter').addEventListener('change', function () {
        const url = new URL(window.location.href);
        if (this.value) {
            url.searchParams.set('status', this.value);
        } else {
            url.searchParams.delete('status');
        }
        window.location.href = url.toString();
    });
</script>
{% endblock %}
