{% extends 'baseBack.html.twig' %}

{% block title %}Marketplace - Admin{% endblock %}
{% block page_title %}Marketplace{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('Front/css/admin.css') }}">
{% endblock %}

{% block body %}
<div class="card admin-card" style="max-width:900px;margin:1rem auto;padding:2rem;border-radius:10px;background:#fff;">

    <h1 style="font-size:1.6rem;font-weight:700;color:#1a2e1a;margin-bottom:.4rem;">Marketplace Management</h1>
    <p style="color:#6b7280;font-size:.9rem;margin-bottom:2rem;">Manage all product listings and customer orders from this panel.</p>

    {% for flash in app.flashes('error') %}
        <div class="alert alert-error">{{ flash }}</div>
    {% endfor %}
    {% for flash in app.flashes('success') %}
        <div class="alert alert-success">{{ flash }}</div>
    {% endfor %}

    {% set current_route = app.request.attributes.get('_route') %}
    <div class="mb-8">
        <nav class="flex space-x-1 bg-white rounded-xl p-1 border border-slate-200 shadow-sm">

            <a href="{{ path('admin_marketplace_products') }}"
               class="flex-1 px-4 py-3 text-sm font-medium rounded-lg transition-all duration-200 text-center
               {% if current_route starts with 'admin_marketplace_product' %}
                   bg-green-600 text-white shadow-sm
               {% else %}
                   text-slate-600 hover:text-slate-900 hover:bg-slate-50
               {% endif %}">
                <svg class="w-4 h-4 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                Manage Products
            </a>

            <a href="{{ path('admin_marketplace_orders') }}"
               class="flex-1 px-4 py-3 text-sm font-medium rounded-lg transition-all duration-200 text-center
               {% if current_route starts with 'admin_marketplace_order' %}
                   bg-green-600 text-white shadow-sm
               {% else %}
                   text-slate-600 hover:text-slate-900 hover:bg-slate-50
               {% endif %}">
                <svg class="w-4 h-4 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
                </svg>
                Orders
            </a>

        </nav>
    </div>
</div>
{% endblock %}
