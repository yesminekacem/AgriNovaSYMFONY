<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: DejaVu Sans, sans-serif; font-size: 13px; color: #1f2937; background: #fff; }

    .page { padding: 40px 48px; }

    /* Header */
    .header-table { width: 100%; border-collapse: collapse; margin-bottom: 36px; }
    .brand { font-size: 26px; font-weight: 700; color: #15803d; letter-spacing: -0.5px; }
    .brand-sub { font-size: 11px; color: #6b7280; margin-top: 3px; }
    .invoice-label { font-size: 28px; font-weight: 700; color: #1f2937; text-align: right; }
    .invoice-meta { font-size: 11px; color: #6b7280; text-align: right; margin-top: 4px; }
    .invoice-meta strong { color: #1f2937; }

    /* Divider */
    .divider { border: none; border-top: 2px solid #16a34a; margin: 0 0 28px; }

    /* Info boxes */
    .info-table { width: 100%; border-collapse: collapse; margin-bottom: 32px; }
    .info-box { width: 50%; vertical-align: top; padding-right: 20px; }
    .info-box-right { width: 50%; vertical-align: top; text-align: right; }
    .info-title { font-size: 10px; font-weight: 700; color: #16a34a; text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 8px; }
    .info-value { font-size: 13px; color: #374151; line-height: 1.6; }
    .info-value strong { color: #111827; }

    /* Status badge */
    .badge { display: inline-block; padding: 3px 12px; border-radius: 20px; font-size: 11px; font-weight: 700; }
    .badge-pending  { background: #fef9c3; color: #854d0e; }
    .badge-delivered { background: #dcfce7; color: #15803d; }
    .badge-cancelled { background: #fee2e2; color: #991b1b; }
    .badge-default  { background: #f1f5f9; color: #475569; }

    /* Items table */
    .items-table { width: 100%; border-collapse: collapse; margin-bottom: 24px; }
    .items-table thead tr { background: #15803d; color: #fff; }
    .items-table thead th { padding: 10px 14px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; text-align: left; }
    .items-table thead th.right { text-align: right; }
    .items-table tbody tr { border-bottom: 1px solid #e5e7eb; }
    .items-table tbody tr:last-child { border-bottom: none; }
    .items-table tbody td { padding: 11px 14px; font-size: 13px; vertical-align: middle; }
    .items-table tbody td.right { text-align: right; }
    .items-table tbody tr:nth-child(even) { background: #f9fafb; }

    /* Totals */
    .totals-table { width: 100%; border-collapse: collapse; margin-bottom: 40px; }
    .totals-spacer { width: 60%; }
    .totals-box { width: 40%; }
    .totals-row { border-top: 1px solid #e5e7eb; }
    .totals-label { padding: 8px 14px; font-size: 13px; color: #6b7280; text-align: right; }
    .totals-value { padding: 8px 14px; font-size: 13px; color: #1f2937; text-align: right; font-weight: 600; width: 110px; }
    .totals-grand td { background: #15803d; color: #fff; font-size: 14px; font-weight: 700; border-radius: 4px; }

    /* Footer */
    .footer { border-top: 1px solid #e5e7eb; padding-top: 18px; text-align: center; font-size: 11px; color: #9ca3af; }
    .footer strong { color: #6b7280; }
</style>
</head>
<body>
<div class="page">

    {# ── Header ── #}
    <table class="header-table">
        <tr>
            <td>
                <div class="brand">AgriNova</div>
                <div class="brand-sub">Agricultural Marketplace Platform</div>
            </td>
            <td>
                <div class="invoice-label">INVOICE</div>
                <div class="invoice-meta">
                    <strong># INV-{{ '%05d'|format(order.id) }}</strong><br>
                    Issued: {{ order.createdAt ? order.createdAt|date('d M Y') : '—' }}<br>
                    Order date: {{ order.orderDate ? order.orderDate|date('d M Y') : '—' }}
                </div>
            </td>
        </tr>
    </table>

    <hr class="divider">

    {# ── Bill To / Order Info ── #}
    <table class="info-table">
        <tr>
            <td class="info-box">
                <div class="info-title">Bill To</div>
                <div class="info-value">
                    <strong>{{ order.userId }}</strong><br>
                    {{ order.deliveryAddress|nl2br }}
                </div>
            </td>
            <td class="info-box-right">
                <div class="info-title">Order Details</div>
                <div class="info-value">
                    Order #{{ order.id }}<br>
                    Payment: {{ order.paymentMethod ?? '—' }}<br>
                    Status:
                    {% set s = order.status %}
                    <span class="badge
                        {% if s == 'Pending' %}badge-pending
                        {% elseif s == 'Delivered' %}badge-delivered
                        {% elseif s == 'Cancelled' %}badge-cancelled
                        {% else %}badge-default{% endif %}">
                        {{ s ?? 'Unknown' }}
                    </span>
                </div>
            </td>
        </tr>
    </table>

    {# ── Items Table ── #}
    <table class="items-table">
        <thead>
            <tr>
                <th style="width:40%;">Product</th>
                <th class="right" style="width:15%;">Qty (kg)</th>
                <th class="right" style="width:20%;">Unit Price (TND)</th>
                <th class="right" style="width:25%;">Subtotal (TND)</th>
            </tr>
        </thead>
        <tbody>
            {% for item in order.orderItems %}
            <tr>
                <td>{{ item.productName }}</td>
                <td class="right">{{ item.quantity }}</td>
                <td class="right">{{ item.pricePerUnit|number_format(2) }}</td>
                <td class="right">{{ item.subtotal|number_format(2) }}</td>
            </tr>
            {% else %}
            <tr>
                <td colspan="4" style="text-align:center;color:#9ca3af;padding:20px;">No items found.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    {# ── Totals ── #}
    <table class="totals-table">
        <tr>
            <td class="totals-spacer"></td>
            <td class="totals-box">
                <table style="width:100%;border-collapse:collapse;">
                    <tr class="totals-row totals-grand">
                        <td class="totals-label" style="color:#fff;padding:12px 14px;">TOTAL</td>
                        <td class="totals-value" style="color:#fff;padding:12px 14px;">{{ order.totalPrice|number_format(2) }} TND</td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>

    {# ── Footer ── #}
    <div class="footer">
        <strong>AgriNova</strong> — Agricultural Marketplace &nbsp;|&nbsp;
        Generated on {{ "now"|date('d M Y, H:i') }} &nbsp;|&nbsp;
        Thank you for your order!
    </div>

</div>
</body>
</html>
