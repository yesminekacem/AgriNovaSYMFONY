{% if products is empty %}
    <div class="rounded-3xl border border-slate-200 bg-white p-12 text-center">
        <div class="mb-4 text-4xl">🛒</div>
        <h3 class="text-lg font-semibold text-slate-900">No products available</h3>
        <p class="mt-2 text-sm text-slate-600">Check back later for new product listings</p>
    </div>
{% else %}
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {% for product in products %}
            <div class="rounded-xl border border-slate-200 bg-white p-6 shadow hover:shadow-lg transition">
                <!-- Product Image -->
                <div class="mb-4 h-48 bg-slate-100 rounded-lg flex items-center justify-center overflow-hidden">
                    {% if product.picture %}
                        <img src="/uploads/products/{{ product.picture|replace({'\\': '/'})|split('/')|last }}" alt="{{ product.productName }}" class="w-full h-full object-cover">
                    {% else %}
                        <div class="text-4xl">🌾</div>
                    {% endif %}
                </div>

                <!-- Product Info -->
                <h3 class="text-lg font-semibold text-slate-900">{{ product.productName }}</h3>
                <p class="mt-2 text-sm text-slate-600">{{ product.description }}</p>

                <!-- Availability Badge -->
                <div class="mt-4">
                    <span class="inline-flex rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-800">
                        {{ product.category }}
                    </span>
                </div>

                <!-- Product Details -->
                <div class="mt-4 border-t border-slate-200 pt-4 space-y-2">
                    <div class="flex justify-between text-sm">
                        <span class="text-slate-600">Price:</span>
                        <span class="font-semibold text-slate-900">{{ product.pricePerUnit }} TND/kg</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-slate-600">Available Qty:</span>
                        <span class="font-semibold text-slate-900">{{ product.quantity }} kg</span>
                    </div>
                </div>

                <!-- Add to Cart Form -->
                <form action="{{ path('cart_add', {'listingId': product.listingId}) }}" method="POST" class="mt-6 flex gap-2">
                    <input type="number" name="quantity" min="1" max="{{ product.quantity }}" value="1" class="w-20 rounded-lg border border-slate-300 px-3 py-2 text-sm" required>
                    <button type="submit" class="flex-1 rounded-lg bg-green-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-green-700">
                        Add to Cart
                    </button>
                </form>
            </div>
        {% endfor %}
    </div>
{% endif %}
