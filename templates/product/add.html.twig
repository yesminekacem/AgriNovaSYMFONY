{% extends 'base.html.twig' %}

{% block title %}Add New Product - AgriNova{% endblock %}
{% block page_title %}Add New Product{% endblock %}

{% block body %}
<section class="mx-auto max-w-2xl p-6">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-[0_14px_32px_rgba(20,83,45,0.08)]">
        <h1 class="text-3xl font-semibold text-slate-900">Add New Product</h1>
        <p class="mt-3 text-sm text-slate-600">Fill in the form below to create a new product listing</p>

        {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}} ) }}

        <div class="mt-8 space-y-6">
            <!-- Product Name -->
            <div>
                {{ form_label(form.productName, "Product Name") }}
                {{ form_widget(form.productName) }}
                {{ form_errors(form.productName) }}
            </div>

            <!-- Description -->
            <div>
                {{ form_label(form.description, "Description") }}
                {{ form_widget(form.description) }}
                {{ form_errors(form.description) }}
            </div>

            <!-- Quantity -->
            <div>
                {{ form_label(form.quantity, "Quantity") }}
                {{ form_widget(form.quantity) }}
                {{ form_errors(form.quantity) }}
            </div>

            <!-- Price Per Unit -->
            <div>
                {{ form_label(form.pricePerUnit, "Price Per Kg (TND)") }}
                {{ form_widget(form.pricePerUnit) }}
                {{ form_errors(form.pricePerUnit) }}
            </div>

            <!-- Category/Availability -->
            <div>
                {{ form_label(form.category, "Category") }}
                {{ form_widget(form.category) }}
                {{ form_errors(form.category) }}
            </div>

            <!-- Status -->
            <div>
                {{ form_label(form.status, "Status") }}
                {{ form_widget(form.status) }}
                {{ form_errors(form.status) }}
            </div>

            <!-- Picture/Image Path -->
            <div>
                {{ form_label(form.picture, "Product Image") }}
                {{ form_widget(form.picture) }}
                {{ form_errors(form.picture) }}
            </div>
        </div>

        <!-- Form Buttons -->
        <div class="mt-8 flex gap-3">
            {{ form_widget(form.save) }}
            <a href="{{ path('product_manage') }}" class="inline-flex items-center rounded-xl border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
                Cancel
            </a>
        </div>

        {{ form_end(form) }}
    </div>
</section>

<style>
    label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 600;
        color: #1f2937;
        font-size: 0.875rem;
    }

    input[type="text"],
    input[type="number"],
    input[type="file"],
    select,
    textarea {
        display: block;
        width: 100%;
        padding: 0.75rem;
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        font-size: 0.875rem;
        font-family: inherit;
        margin-top: 0.25rem;
        transition: border-color 0.2s;
    }

    input[type="text"]:focus,
    input[type="number"]:focus,
    input[type="file"]:focus,
    select:focus,
    textarea:focus {
        outline: none;
        border-color: #16a34a;
        box-shadow: 0 0 0 3px rgba(22, 163, 74, 0.1);
    }

    input[type="file"] {
        cursor: pointer;
    }

    .form_errors ul {
        list-style: none;
        padding: 0;
        margin: 0.5rem 0 0 0;
    }

    .form_errors li {
        color: #dc2626;
        font-size: 0.75rem;
        margin-top: 0.25rem;
    }

    button[type="submit"] {
        background-color: #16a34a;
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        border: none;
        font-weight: 600;
        cursor: pointer;
        font-size: 0.875rem;
        transition: background-color 0.2s;
    }

    button[type="submit"]:hover {
        background-color: #15803d;
    }
</style>
{% endblock %}
