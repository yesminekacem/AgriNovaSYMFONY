{% extends 'base.html.twig' %}

{% block title %}Manage Products - AgriNova{% endblock %}
{% block page_title %}Manage Products{% endblock %}

{% block body %}
<section class="mx-auto max-w-6xl p-6">
    {% include 'product/_marketplace_nav.html.twig' %}

    <div class="mb-8">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-semibold text-slate-900">My Products</h1>
                <p class="mt-2 text-sm text-slate-600">Manage your marketplace product listings</p>
            </div>
            <a href="{{ path('product_add') }}" class="inline-flex items-center rounded-xl bg-green-700 px-5 py-3 text-sm font-semibold text-white transition hover:bg-green-800">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mr-2">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
                Create New Product
            </a>
        </div>
    </div>

    <!-- Flash Messages -->
    {% for message in app.flashes('success') %}
        <div class="mb-4 rounded-lg bg-green-100 border border-green-400 text-green-700 px-4 py-3">
            {{ message }}
        </div>
    {% endfor %}

    {% if products is empty %}
        <div class="rounded-3xl border border-slate-200 bg-white p-12 text-center">
            <div class="mb-4 text-4xl">📦</div>
            <h3 class="text-lg font-semibold text-slate-900">No products yet</h3>
            <p class="mt-2 text-sm text-slate-600">Start by creating your first product listing</p>
            <a href="{{ path('product_add') }}" class="mt-4 inline-flex items-center rounded-xl bg-green-700 px-5 py-3 text-sm font-semibold text-white transition hover:bg-green-800">
                Create Your First Product
            </a>
        </div>
    {% else %}
        <div class="overflow-x-auto rounded-xl border border-slate-200 bg-white shadow">
            <table class="w-full">
                <thead class="border-b border-slate-200 bg-slate-50">
                    <tr>
                        <th class="px-6 py-4 text-left text-sm font-semibold text-slate-900">Image</th>
                        <th class="px-6 py-4 text-left text-sm font-semibold text-slate-900">Product Name</th>
                        <th class="px-6 py-4 text-left text-sm font-semibold text-slate-900">Quantity</th>
                        <th class="px-6 py-4 text-left text-sm font-semibold text-slate-900">Price (TND)</th>
                        <th class="px-6 py-4 text-left text-sm font-semibold text-slate-900">Category</th>
                        <th class="px-6 py-4 text-left text-sm font-semibold text-slate-900">Status</th>
                        <th class="px-6 py-4 text-right text-sm font-semibold text-slate-900">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200">
                    {% for product in products %}
                        <tr class="hover:bg-slate-50">
                            <td class="px-6 py-4">
                                <div class="h-12 w-12 flex-shrink-0 bg-slate-100 rounded-md flex items-center justify-center overflow-hidden">
                                    {% if product.picture %}
                                        <img src="/uploads/products/{{ product.picture }}" alt="{{ product.productName }}" class="h-full w-full object-cover">
                                    {% else %}
                                        <span class="text-xl">🌾</span>
                                    {% endif %}
                                </div>
                            </td>
                            <td class="px-6 py-4 text-sm font-medium text-slate-900">{{ product.productName }}</td>
                            <td class="px-6 py-4 text-sm text-slate-600">{{ product.quantity }}</td>
                            <td class="px-6 py-4 text-sm text-slate-600">{{ product.pricePerUnit }}</td>
                            <td class="px-6 py-4 text-sm">
                                <span class="inline-flex rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-800">
                                    {{ product.category }}
                                </span>
                            </td>
                            <td class="px-6 py-4 text-sm">
                                {% if product.status == 'available' %}
                                    <span class="inline-flex rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-800">
                                        Available
                                    </span>
                                {% elseif product.status == 'sold-out' %}
                                    <span class="inline-flex rounded-full bg-red-100 px-3 py-1 text-xs font-semibold text-red-800">
                                        Sold Out
                                    </span>
                                {% else %}
                                    <span class="inline-flex rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-800">
                                        Not Set
                                    </span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 text-right text-sm font-medium">
                                <a href="{{ path('product_edit', {'id': product.listingId}) }}" class="inline-flex items-center rounded-lg bg-blue-600 px-3 py-2 text-xs font-semibold text-white transition hover:bg-blue-700">
                                    Edit
                                </a>
                                <a href="{{ path('product_delete', {'id': product.listingId}) }}" class="ml-2 inline-flex items-center rounded-lg bg-red-600 px-3 py-2 text-xs font-semibold text-white transition hover:bg-red-700" onclick="return confirm('Are you sure?')">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</section>
{% endblock %}
