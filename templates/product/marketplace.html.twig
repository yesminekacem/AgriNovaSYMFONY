{% extends 'base.html.twig' %}

{% block title %}Marketplace - AgriNova{% endblock %}
{% block page_title %}Marketplace{% endblock %}

{% block body %}
<section class="mx-auto max-w-6xl p-6">
    {% include 'product/_marketplace_nav.html.twig' %}

    <div class="mb-8">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-semibold text-slate-900">Marketplace</h1>
                <p class="mt-2 text-sm text-slate-600">Browse products from other farmers and purchase directly</p>
            </div>
            
            <!-- Search and Filter -->
            <div class="flex items-center gap-3">
                <!-- Category Filter Dropdown -->
                <div class="relative">
                    <select id="category-filter" class="appearance-none block pl-4 pr-10 py-3 text-sm text-gray-900 border border-slate-300 rounded-lg bg-gray-50 focus:ring-green-500 focus:border-green-500 cursor-pointer">
                        <option value="" {% if currentCategory is not defined or not currentCategory %}selected{% endif %}>All Categories</option>
                        <option value="Vegetables" {% if currentCategory == 'Vegetables' %}selected{% endif %}>Vegetables</option>
                        <option value="Fruits" {% if currentCategory == 'Fruits' %}selected{% endif %}>Fruits</option>
                        <option value="Grains" {% if currentCategory == 'Grains' %}selected{% endif %}>Grains</option>
                    </select>
                    <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                        <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                        </svg>
                    </div>
                </div>

                <!-- Live Search Bar -->
                <div class="relative w-72">
                    <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                        <svg aria-hidden="true" class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                        </svg>
                    </div>
                    <input type="search" id="marketplace-search" class="block w-full p-3 pl-10 text-sm text-gray-900 border border-slate-300 rounded-lg bg-gray-50 focus:ring-green-500 focus:border-green-500" placeholder="Search products by name...">
                </div>
            </div>
        </div>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 rounded-lg p-4 {% if label == 'success' %}bg-green-100 text-green-800{% else %}bg-red-100 text-red-800{% endif %}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <!-- Product Grid Container -->
    <div id="products-container">
        {% include 'product/_marketplace_products.html.twig' %}
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('marketplace-search');
            const categoryFilter = document.getElementById('category-filter');
            const productsContainer = document.getElementById('products-container');
            let debounceTimer;

            function fetchProducts() {
                const query = searchInput.value;
                const category = categoryFilter.value;

                let url = '{{ path("product_marketplace") }}?q=' + encodeURIComponent(query);
                if (category) {
                    url += '&category=' + encodeURIComponent(category);
                }

                fetch(url, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(response => response.text())
                .then(html => {
                    productsContainer.innerHTML = html;
                })
                .catch(error => console.error('Error fetching results:', error));
            }

            searchInput.addEventListener('input', function() {
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(fetchProducts, 300);
            });

            categoryFilter.addEventListener('change', fetchProducts);
        });
    </script>
</section>

<style>
    .grid {
        display: grid;
    }

    .gap-6 {
        gap: 1.5rem;
    }

    .md\:grid-cols-2 {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .lg\:grid-cols-3 {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    @media (max-width: 768px) {
        .md\:grid-cols-2 {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 1024px) {
        .lg\:grid-cols-3 {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }
</style>
{% endblock %}
