<form method="post" action="{{ path('rental_delete', {id: rental.id}) }}" onsubmit="return confirm('Delete rental #{{ rental.id }}?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete_rental_' ~ rental.id) }}">
    <button class="inline-flex items-center rounded-xl border border-red-200 bg-red-50 px-4 py-2 text-sm font-semibold text-red-700 transition hover:bg-red-100">
        Delete
    </button>
</form>
