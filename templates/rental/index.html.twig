{% extends is_granted('ROLE_ADMIN') ? 'baseBack.html.twig' : 'base.html.twig' %}

{% block title %}Rentals{% endblock %}
{% block page_title %}Rentals{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .rental-surface { background: #fff; border: 1px solid #dce9df; border-radius: 1.25rem; box-shadow: 0 14px 32px rgba(20, 83, 45, 0.08); }
        .rental-stat { background: linear-gradient(180deg, #ffffff 0%, #f7fbf8 100%); }
        .rental-table thead th { font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; color: #64748b; }
        .rental-table tbody tr:hover { background: #f8fcf9; }
        .rental-badge { display: inline-flex; align-items: center; border-radius: 999px; padding: 0.35rem 0.75rem; font-size: 0.75rem; font-weight: 700; }
    </style>
{% endblock %}

{% block body %}
    {% set statusColors = {'PENDING':'bg-amber-100 text-amber-700','APPROVED':'bg-blue-100 text-blue-700','ACTIVE':'bg-emerald-100 text-emerald-700','RETURNED':'bg-indigo-100 text-indigo-700','COMPLETED':'bg-slate-200 text-slate-700','CANCELLED':'bg-red-100 text-red-700','DISPUTED':'bg-rose-100 text-rose-700'} %}
    {% set paymentColors = {'PENDING':'bg-amber-100 text-amber-700','DEPOSIT_PAID':'bg-blue-100 text-blue-700','FULLY_PAID':'bg-emerald-100 text-emerald-700','REFUNDED':'bg-slate-200 text-slate-700','DISPUTED':'bg-rose-100 text-rose-700'} %}

    <div class="space-y-6">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="rounded-2xl border px-4 py-3 text-sm font-medium {{ label == 'success' ? 'border-green-200 bg-green-50 text-green-700' : 'border-red-200 bg-red-50 text-red-700' }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <section class="rental-surface p-6">
            <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
                <div>
                    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-green-700">Rental Workspace</p>
                    <h1 class="mt-2 text-3xl font-bold text-slate-900">Track bookings, returns, and revenue</h1>
                    <p class="mt-2 max-w-3xl text-sm text-slate-500">This module uses DQL-based search and filters, automatic cost calculation, and a dedicated rental history log.</p>
                </div>
                <div class="flex flex-wrap gap-3">
                    {% if inventoryItem and inventoryItem.id and inventoryItem.isRentable and inventoryItem.rentalStatus not in ['RENTED_OUT', 'IN_USE', 'MAINTENANCE', 'RETIRED'] %}
                        <a href="{{ path('rental_new', {inventory: inventoryItem.id}) }}" class="inline-flex items-center rounded-xl bg-green-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-green-800">New rental</a>
                    {% endif %}
                    {% if inventoryItem and inventoryItem.id %}
                        <a href="{{ path('inventory_show', {id: inventoryItem.id}) }}" class="inline-flex items-center rounded-xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">Back to inventory</a>
                    {% else %}
                        <a href="{{ path('inventory_index') }}" class="inline-flex items-center rounded-xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">Inventory</a>
                    {% endif %}
                    <a href="{{ path('rental_export_csv', {search: search, status: status, paymentStatus: paymentStatus, overdue: overdueOnly ? 1 : 0, inventory: inventoryItem ? inventoryItem.id : null}) }}" class="inline-flex items-center rounded-xl border border-green-200 bg-green-50 px-4 py-2 text-sm font-semibold text-green-700 transition hover:bg-green-100">Export CSV</a>
                    <a href="{{ path('rental_history_index') }}" class="inline-flex items-center rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800">Rental history</a>
                </div>
            </div>
        </section>

        {% if inventoryItem and inventoryItem.id %}
            <section class="rental-surface border border-blue-100 bg-blue-50 p-5">
                <p class="text-sm font-semibold uppercase tracking-[0.14em] text-blue-700">Inventory Context</p>
                <h2 class="mt-2 text-xl font-bold text-slate-900">{{ inventoryItem.itemName }}</h2>
                <p class="mt-2 text-sm text-slate-600">Only rentals linked to this inventory item are shown here.</p>
            </section>
        {% endif %}

        <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-6">
            <article class="rental-surface rental-stat p-5"><p class="text-sm text-slate-500">Total rentals</p><p class="mt-2 text-3xl font-bold text-slate-900">{{ stats.total }}</p></article>
            <article class="rental-surface rental-stat p-5"><p class="text-sm text-slate-500">Pending</p><p class="mt-2 text-3xl font-bold text-slate-900">{{ stats.pending }}</p></article>
            <article class="rental-surface rental-stat p-5"><p class="text-sm text-slate-500">Active</p><p class="mt-2 text-3xl font-bold text-slate-900">{{ stats.active }}</p></article>
            <article class="rental-surface rental-stat p-5"><p class="text-sm text-slate-500">Completed</p><p class="mt-2 text-3xl font-bold text-slate-900">{{ stats.completed }}</p></article>
            <article class="rental-surface rental-stat p-5"><p class="text-sm text-slate-500">Overdue</p><p class="mt-2 text-3xl font-bold text-slate-900">{{ stats.overdue }}</p></article>
            <article class="rental-surface rental-stat p-5"><p class="text-sm text-slate-500">Revenue</p><p class="mt-2 text-3xl font-bold text-slate-900">{{ stats.revenue|number_format(2, '.', ',') }}</p></article>
        </section>

        <section class="rental-surface p-6">
            <form method="get" class="grid gap-4 md:grid-cols-2 xl:grid-cols-5">
                <div class="xl:col-span-2">
                    <label class="mb-2 block text-sm font-semibold text-slate-700">Search</label>
                    <input type="text" name="search" value="{{ search }}" placeholder="Search by renter, owner, item or contact" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700 outline-none transition focus:border-green-500 focus:ring-4 focus:ring-green-100">
                </div>
                <div>
                    <label class="mb-2 block text-sm font-semibold text-slate-700">Rental status</label>
                    <select name="status" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700 outline-none transition focus:border-green-500 focus:ring-4 focus:ring-green-100">
                        <option value="">All statuses</option>
                        {% for value in statuses %}<option value="{{ value }}" {{ status == value ? 'selected' : '' }}>{{ value }}</option>{% endfor %}
                    </select>
                </div>
                <div>
                    <label class="mb-2 block text-sm font-semibold text-slate-700">Payment status</label>
                    <select name="paymentStatus" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700 outline-none transition focus:border-green-500 focus:ring-4 focus:ring-green-100">
                        <option value="">All payments</option>
                        {% for value in paymentStatuses %}<option value="{{ value }}" {{ paymentStatus == value ? 'selected' : '' }}>{{ value }}</option>{% endfor %}
                    </select>
                </div>
                <div>
                    <label class="mb-2 block text-sm font-semibold text-slate-700">Flags</label>
                    <label class="flex h-[50px] items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 text-sm font-semibold text-slate-700"><input type="checkbox" name="overdue" value="1" {{ overdueOnly ? 'checked' : '' }}>Overdue only</label>
                </div>
                <div class="xl:col-span-5 flex flex-wrap gap-3">
                    {% if inventoryItem and inventoryItem.id %}
                        <input type="hidden" name="inventory" value="{{ inventoryItem.id }}">
                    {% endif %}
                    <button class="inline-flex items-center rounded-xl bg-green-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-green-800">Apply filters</button>
                    <a href="{{ inventoryItem and inventoryItem.id ? path('rental_index', {inventory: inventoryItem.id}) : path('rental_index') }}" class="inline-flex items-center rounded-xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">Reset</a>
                    <span class="inline-flex items-center rounded-xl bg-slate-100 px-4 py-2 text-sm font-medium text-slate-600">{{ rentals|length }} result{{ rentals|length == 1 ? '' : 's' }}</span>
                </div>
            </form>
        </section>

        <section class="grid gap-6 xl:grid-cols-[minmax(0,2fr)_minmax(320px,1fr)]">
            <article class="rental-surface overflow-hidden">
                <div class="flex items-center justify-between border-b border-slate-100 px-6 py-4">
                    <div><h2 class="text-lg font-bold text-slate-900">Rental list</h2><p class="text-sm text-slate-500">Status actions also write into the rental history table.</p></div>
                </div>
                {% if rentals is empty %}
                    <div class="px-6 py-14 text-center"><h3 class="text-xl font-semibold text-slate-800">No rentals matched this filter.</h3><p class="mt-2 text-sm text-slate-500">Try resetting the filters or create a new rental.</p></div>
                {% else %}
                    <div class="overflow-x-auto">
                        <table class="rental-table min-w-full divide-y divide-slate-100">
                            <thead class="bg-slate-50"><tr><th class="px-6 py-4 text-left">Rental</th><th class="px-6 py-4 text-left">Dates</th><th class="px-6 py-4 text-left">Status</th><th class="px-6 py-4 text-left">Costs</th><th class="px-6 py-4 text-right">Actions</th></tr></thead>
                            <tbody class="divide-y divide-slate-100 bg-white">
                                {% for rental in rentals %}
                                    <tr>
                                        {% set isRentalOwner = is_granted('ROLE_ADMIN') or (app.user and rental.renterContact is not empty and rental.renterContact|lower == app.user.email|lower) %}
                                        <td class="px-6 py-4 align-top">
                                            <div class="flex flex-col gap-2">
                                                <a href="{{ path('rental_show', {id: rental.id}) }}" class="font-semibold text-slate-900 hover:text-green-700">#{{ rental.id }} · {{ rental.displayItemName }}</a>
                                                <p class="text-sm text-slate-600">{{ rental.renterName }} · {{ rental.renterContact }}</p>
                                                <p class="text-xs text-slate-500">Owner: {{ rental.ownerName }}</p>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 align-top text-sm text-slate-600">
                                            <p>{{ rental.startDate ? rental.startDate|date('d M Y') : 'N/A' }}</p>
                                            <p class="mt-1">{{ rental.endDate ? rental.endDate|date('d M Y') : 'N/A' }}</p>
                                            <p class="mt-2 text-xs {{ rental.overdue ? 'text-red-600' : 'text-slate-500' }}">{{ rental.overdue ? 'Overdue' : rental.daysRemaining ~ ' day(s) remaining' }}</p>
                                        </td>
                                        <td class="px-6 py-4 align-top text-sm text-slate-600">
                                            <span class="rental-badge {{ statusColors[rental.rentalStatus]|default('bg-slate-200 text-slate-700') }}">{{ rental.rentalStatus }}</span>
                                            <div class="mt-2"><span class="rental-badge {{ paymentColors[rental.paymentStatus]|default('bg-slate-200 text-slate-700') }}">{{ rental.paymentStatus }}</span></div>
                                        </td>
                                        <td class="px-6 py-4 align-top text-sm text-slate-600">
                                            <p>Total: <span class="font-semibold text-slate-900">{{ rental.totalCost|default(0)|number_format(2, '.', ',') }}</span></p>
                                            <p class="mt-1 text-xs text-slate-500">Deposit: {{ rental.securityDeposit|default(0)|number_format(2, '.', ',') }}</p>
                                            <p class="mt-1 text-xs text-slate-500">Late fee: {{ rental.lateFee|default(0)|number_format(2, '.', ',') }}</p>
                                        </td>
                                        <td class="px-6 py-4 align-top">
                                            <div class="flex flex-wrap justify-end gap-2">
                                                <a href="{{ path('rental_show', {id: rental.id}) }}" class="rounded-xl border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-700 transition hover:bg-slate-50">View</a>
                                                {% if is_granted('ROLE_ADMIN') %}
                                                    <a href="{{ path('rental_edit', {id: rental.id}) }}" class="rounded-xl bg-green-700 px-3 py-2 text-xs font-semibold text-white transition hover:bg-green-800">Edit</a>
                                                {% endif %}
                                                {% if isRentalOwner %}
                                                    {% if rental.rentalStatus == 'PENDING' %}
                                                        {{ include('rental/_action_form.html.twig', {rental: rental, route: 'rental_approve', label: 'Approve', actionType: 'APPROVED', buttonClass: 'rounded-xl border border-blue-200 bg-blue-50 px-3 py-2 text-xs font-semibold text-blue-700 transition hover:bg-blue-100'}) }}
                                                        {{ include('rental/_action_form.html.twig', {rental: rental, route: 'rental_cancel', label: 'Cancel', actionType: 'CANCELLED', buttonClass: 'rounded-xl border border-red-200 bg-red-50 px-3 py-2 text-xs font-semibold text-red-700 transition hover:bg-red-100'}) }}
                                                    {% elseif rental.rentalStatus == 'APPROVED' %}
                                                        {{ include('rental/_action_form.html.twig', {rental: rental, route: 'rental_activate', label: 'Activate', actionType: 'ACTIVATED', buttonClass: 'rounded-xl border border-emerald-200 bg-emerald-50 px-3 py-2 text-xs font-semibold text-emerald-700 transition hover:bg-emerald-100'}) }}
                                                        {{ include('rental/_action_form.html.twig', {rental: rental, route: 'rental_cancel', label: 'Cancel', actionType: 'CANCELLED', buttonClass: 'rounded-xl border border-red-200 bg-red-50 px-3 py-2 text-xs font-semibold text-red-700 transition hover:bg-red-100'}) }}
                                                    {% elseif rental.rentalStatus == 'ACTIVE' %}
                                                        {{ include('rental/_action_form.html.twig', {rental: rental, route: 'rental_return', label: 'Return', actionType: 'RETURNED', buttonClass: 'rounded-xl border border-indigo-200 bg-indigo-50 px-3 py-2 text-xs font-semibold text-indigo-700 transition hover:bg-indigo-100'}) }}
                                                        {{ include('rental/_action_form.html.twig', {rental: rental, route: 'rental_complete', label: 'Complete', actionType: 'COMPLETED', buttonClass: 'rounded-xl border border-slate-200 bg-slate-100 px-3 py-2 text-xs font-semibold text-slate-700 transition hover:bg-slate-200'}) }}
                                                        {{ include('rental/_action_form.html.twig', {rental: rental, route: 'rental_dispute', label: 'Dispute', actionType: 'DISPUTED', buttonClass: 'rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-xs font-semibold text-rose-700 transition hover:bg-rose-100'}) }}
                                                    {% elseif rental.rentalStatus == 'RETURNED' %}
                                                        {{ include('rental/_action_form.html.twig', {rental: rental, route: 'rental_complete', label: 'Complete', actionType: 'COMPLETED', buttonClass: 'rounded-xl border border-slate-200 bg-slate-100 px-3 py-2 text-xs font-semibold text-slate-700 transition hover:bg-slate-200'}) }}
                                                    {% endif %}
                                                {% endif %}
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </article>

            <aside class="space-y-6">
                <article class="rental-surface p-6">
                    <h2 class="text-lg font-bold text-slate-900">Upcoming returns</h2>
                    <p class="mt-1 text-sm text-slate-500">Approved or active rentals ending soon.</p>
                    <div class="mt-5 space-y-4">
                        {% if upcomingReturns is empty %}
                            <p class="text-sm text-slate-500">No near-term returns right now.</p>
                        {% else %}
                            {% for rental in upcomingReturns %}
                                <div class="rounded-2xl border border-blue-100 bg-blue-50 p-4">
                                    <p class="font-semibold text-slate-900">#{{ rental.id }} · {{ rental.displayItemName }}</p>
                                    <p class="mt-1 text-sm text-slate-600">{{ rental.renterName }}</p>
                                    <p class="mt-2 text-xs font-semibold uppercase tracking-[0.14em] text-blue-700">Ends {{ rental.endDate|date('d M Y') }}</p>
                                </div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </article>
                <article class="rental-surface p-6">
                    <h2 class="text-lg font-bold text-slate-900">Overdue watch</h2>
                    <p class="mt-1 text-sm text-slate-500">Rentals that have passed their end date without return.</p>
                    <div class="mt-5 space-y-4">
                        {% if overdueRentals is empty %}
                            <p class="text-sm text-slate-500">Nothing overdue right now.</p>
                        {% else %}
                            {% for rental in overdueRentals %}
                                <div class="rounded-2xl border border-red-100 bg-red-50 p-4">
                                    <p class="font-semibold text-slate-900">#{{ rental.id }} · {{ rental.displayItemName }}</p>
                                    <p class="mt-1 text-sm text-slate-600">{{ rental.renterName }}</p>
                                    <p class="mt-2 text-xs font-semibold uppercase tracking-[0.14em] text-red-700">{{ (0 - rental.daysRemaining) }} day(s) overdue</p>
                                </div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </article>
            </aside>
        </section>
    </div>
{% endblock %}
