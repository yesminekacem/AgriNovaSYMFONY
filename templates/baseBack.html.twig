<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}AgriNova{% endblock %} - Smart Farm Platform</title>

    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌿</text></svg>">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Outfit:wght@600;700&display=swap" rel="stylesheet">

    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet" href="{{ asset('Front/css/base.css') }}">

    {% block stylesheets %}{% endblock %}
</head>
<body>

    {# ════════════════════════════════ SIDEBAR ════════════════════════════════ #}
    <aside class="sidebar" id="sidebar">

        <div class="sidebar-brand">
            <div class="brand-icon">🌿</div>
            <div class="brand-text">
                <h1>AGRINOVA</h1>
                <span>Smart Farm Platform</span>
            </div>
        </div>

        <p class="nav-section-label">Management</p>
        <ul class="nav-list">
            <li class="nav-item {% if app.request.attributes.get('_route') starts with 'dashboard' %}active{% endif %}">
                <a href="{{ path('app_dashboard') }}">
                    <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                    </svg>
                    Dashboard
                </a>
            </li>
            <li class="nav-item {% if app.request.attributes.get('_route') starts with 'user' %}active{% endif %}">
                <a href="{{ path('admin_users') }}">
                    <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    Users
                </a>
            </li>
            <li class="nav-item">
                <a href="{{ path('admin_marketplace') }}">
                    <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                    Marketplace
                </a>
            </li>
            <li class="nav-item {% if app.request.attributes.get('_route') starts with 'inventory' %}active{% endif %}">
                 <a href="{{ path('inventory_index') }}">
                    <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                    </svg>
                    Inventory
                </a>
            </li>
            <li class="nav-item {% if app.request.attributes.get('_route') starts with 'crop' %}active{% endif %}">
                <a href="{{ path('app_crop_table') }}">
                    <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                    </svg>
                    Crops
                </a>
            </li>
            <li class="nav-item {% if app.request.attributes.get('_route') starts with 'forum' %}active{% endif %}">
                <a href="{{ path('app_forum_back') }}">
                    <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                    </svg>
                    Forum
                </a>
            </li>
        </ul>

        <div class="sidebar-footer">
            <div class="user-card">
                <div class="user-avatar">
    {% if app.user and app.user.profileImage %}
        <img src="{{ asset('uploads/profile_images/' ~ app.user.profileImage) }}" alt="Profile">
    {% else %}
        {{ app.user ? app.user.username|first|upper : 'A' }}
    {% endif %}
</div>
                <div class="user-info">
                    <p>{{ app.user ? app.user.username : 'Admin' }}</p>
                    <span>Administrator</span>
                </div>
            </div>
        </div>

    </aside>

    {# ════════════════════════════════ MAIN WRAPPER ════════════════════════════════ #}
    <div class="main-wrapper">

        <header class="top-header">
            <div class="header-left">
                <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
                    <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#374151" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
                    </svg>
                </button>
                <nav class="breadcrumb" aria-label="Breadcrumb">
                    <span>AgriNova</span>
                    <span class="sep">›</span>
                    <span class="current">{% block page_title '' %}</span>
                </nav>
            </div>

            <div class="header-right">

                <button class="header-btn" aria-label="Notifications">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#6b7280" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
                    </svg>
                    <span class="notif-dot"></span>
                </button>

                {% if app.user %}
                    <div class="header-avatar" title="{{ app.user.username }}">
    <a href="{{ path('app_profile') }}" style="display:block;">
        {% if app.user and app.user.profileImage %}
            <img src="{{ asset('uploads/profile_images/' ~ app.user.profileImage) }}" alt="Profile">
        {% else %}
            <span>{{ app.user.username|first|upper }}</span>
        {% endif %}
    </a>
</div>
                    <form id="logout-form" action="{{ path('app_logout') }}" method="post" style="display:inline;margin-left:12px;">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                        <button class="btn btn-logout" type="submit">Logout</button>
                    </form>
                {% else %}
                    <a class="btn" href="{{ path('app_login') }}" style="margin-left:12px;">Login</a>
                    <a class="btn" href="{{ path('app_register') }}" style="margin-left:8px;">Register</a>
                {% endif %}
            </div>
        </header>

        <main class="page-content">
            {% block body %}{% endblock %}
        </main>

    </div>

    <script src="{{ asset('Front/js/base.js') }}"></script>
    {% block javascripts %}{% endblock %}

</body>
</html>
