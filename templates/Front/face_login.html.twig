<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Face Login – AGRINOVA</title>
    <link rel="stylesheet" href="{{ asset('Front/css/login.css') }}">
</head>
<body>
<div class="container">
    <div class="card">
        <h2>Face ID Login</h2>

        {% for flash in app.flashes('error') %}
            <div class="alert alert-error">{{ flash }}</div>
        {% endfor %}
        {% for flash in app.flashes('success') %}
            <div class="alert alert-success">{{ flash }}</div>
        {% endfor %}

        <form method="post" action="{{ path('app_login_face') }}" enctype="multipart/form-data">
            <div class="field">
                <label for="email">Email</label>
                <input id="email" name="email" type="email" required>
            </div>

            <div class="field">
                <label>Use camera to capture your face</label>
                <div class="face-camera-widget" data-auto-submit="0">
                    <video class="face-video" autoplay playsinline style="width:100%;max-width:360px;border-radius:8px;background:#000;transform: scaleX(-1);-webkit-transform: scaleX(-1);"></video>
                    <canvas class="face-canvas" style="display:none"></canvas>
                    <img class="face-preview-img" src="" alt="preview" style="display:block;margin-top:8px;width:120px;height:120px;border-radius:999px;object-fit:cover;"/>
                    <div style="margin-top:8px;display:flex;gap:8px">
                        <button type="button" class="face-start-btn btn">Start camera</button>
                        <button type="button" class="face-stop-btn btn">Stop</button>
                        <button type="button" class="face-capture-btn btn">Capture</button>
                    </div>
                    <input type="hidden" name="face_image_base64" value="">
                </div>
            </div>

            <div class="field" style="margin-top:12px">
                <label for="face_image">Or upload a photo</label>
                <input id="face_image" name="face_image" type="file" accept="image/*">
            </div>

            <div class="actions">
                <button type="submit" class="btn-submit">Login with Face ID</button>
            </div>
        </form>

        <div class="note" style="margin-top:12px">
            <a href="{{ path('app_login') }}">Back to password login</a>
        </div>
    </div>
</div>
<script src="{{ asset('Front/js/face.js') }}"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const video = document.querySelector('.face-video');
        const canvas = document.querySelector('.face-canvas');
        const previewImg = document.querySelector('.face-preview-img');
        const faceImageInput = document.querySelector('input[name="face_image_base64"]');

        let stream = null;

        // Start the camera automatically
        navigator.mediaDevices.getUserMedia({ video: true })
            .then((mediaStream) => {
                stream = mediaStream;
                video.srcObject = stream;

                // Apply horizontal inversion to the video feed
                video.style.transform = 'rotateY(180deg)';
                video.style.webkitTransform = 'rotateY(180deg)'; // For Safari compatibility
            })
            .catch((err) => {
                console.error('Error accessing the camera:', err);
            });

        // Continuously capture frames and send for detection
        const detectFace = () => {
            const context = canvas.getContext('2d');
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;

            // Flip the canvas horizontally to match the inverted video feed
            context.translate(canvas.width, 0);
            context.scale(-1, 1);
            context.drawImage(video, 0, 0, canvas.width, canvas.height);

            const imageData = canvas.toDataURL('image/png');
            faceImageInput.value = imageData;

            // Send the image to the server for detection
            fetch('{{ path('app_login_face_detect') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ face_image: imageData }),
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        window.location.href = '{{ path('app_profile') }}';
                    }
                })
                .catch(err => console.error('Face detection error:', err));
        };

        // Run detection every 2 seconds
        setInterval(detectFace, 2000);

        // Stop the camera when the page is unloaded
        window.addEventListener('beforeunload', () => {
            if (stream) {
                stream.getTracks().forEach(track => track.stop());
            }
        });
    });
</script>
</body>
</html>
