{% extends 'base.html.twig' %}

{% block title %}Marketplace{% endblock %}

{% block stylesheets %}
<style>
    .marketplace-header {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
    }

    .marketplace-tabs {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .marketplace-tab {
        border: 1px solid #d1d5db;
        background: #fff;
        color: #111827;
        padding: 0.75rem 1rem;
        border-radius: 0.75rem;
        cursor: pointer;
        transition: border-color 0.2s, background-color 0.2s, color 0.2s;
    }

    .marketplace-tab.active {
        border-color: #16a34a;
        background: #d1fae5;
        color: #065f46;
    }

    .marketplace-panel {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 1rem;
        padding: 1.5rem;
        box-shadow: 0 16px 40px rgba(15, 23, 42, 0.05);
    }

    .marketplace-panel h2 {
        margin-bottom: 1rem;
        font-size: 1.35rem;
        color: #111827;
    }

    .marketplace-panel p {
        color: #4b5563;
        line-height: 1.75;
    }

    .marketplace-section {
        display: none;
    }

    .marketplace-section.show {
        display: block;
    }

    .product-grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        margin-top: 1rem;
    }

    .product-card {
        border: 1px solid #e5e7eb;
        border-radius: 1rem;
        overflow: hidden;
        background: #fff;
        display: flex;
        flex-direction: column;
        min-height: 100%;
    }

    .product-card img {
        width: 100%;
        height: 180px;
        object-fit: cover;
        object-position: center;
    }

    .product-card-body {
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        flex: 1;
    }

    .product-card h3 {
        margin: 0;
        font-size: 1.1rem;
        color: #111827;
    }

    .product-card p {
        margin: 0;
        color: #4b5563;
        font-size: 0.95rem;
        line-height: 1.5;
    }

    .product-meta {
        display: grid;
        gap: 0.65rem;
        margin-top: auto;
        font-size: 0.9rem;
        color: #374151;
    }

    .meta-row {
        display: flex;
        justify-content: space-between;
        gap: 0.75rem;
    }

    .meta-row span:first-child {
        color: #6b7280;
    }

    .badge {
        display: inline-flex;
        align-items: center;
        padding: 0.35rem 0.75rem;
        border-radius: 999px;
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.02em;
    }

    .badge-available {
        background: #dcfce7;
        color: #166534;
    }

    .badge-sold-out {
        background: #fee2e2;
        color: #991b1b;
    }
</style>
{% endblock %}

{% block body %}
    <div class="marketplace-header">
        <div>
            <h1>Marketplace</h1>
            <p class="text-sm text-gray-500">Browse products, manage your listings, review cart items, and check orders.</p>
        </div>
        <div class="marketplace-tabs" role="tablist" aria-label="Marketplace navigation">
            <button class="marketplace-tab active" data-tab="marketplace">Marketplace</button>
            <button class="marketplace-tab" data-tab="products">Manage Products</button>
            <button class="marketplace-tab" data-tab="cart">Cart</button>
            <button class="marketplace-tab" data-tab="orders">Orders</button>
        </div>
    </div>

    <div class="marketplace-panel">
        <section id="marketplace" class="marketplace-section show" data-panel="marketplace">
            <h2>Marketplace</h2>

            {% if products is empty %}
                <p>No products are available right now.</p>
            {% else %}
                <div class="product-grid">
                    {% for product in products %}
                        <article class="product-card">
                            <img src="{{ product.picture starts with 'http://' or product.picture starts with 'https://' ? product.picture : asset(product.picture) }}" alt="{{ product.product_name }}">
                            <div class="product-card-body">
                                <h3>{{ product.product_name }}</h3>
                                <p>{{ product.description }}</p>
                                <div class="product-meta">
                                    <div class="meta-row">
                                        <span>Seller</span>
                                        <strong>{{ product.user_id }}</strong>
                                    </div>
                                    <div class="meta-row">
                                        <span>Price / unit</span>
                                        <strong>{{ product.price_per_unit }} USD</strong>
                                    </div>
                                    <div class="meta-row">
                                        <span>Available</span>
                                        <strong>{{ product.quantity }}</strong>
                                    </div>
                                    <div class="meta-row">
                                        <span>Status</span>
                                        <strong><span class="badge {{ product.status == 'available' ? 'badge-available' : 'badge-sold-out' }}">{{ product.status|upper }}</span></strong>
                                    </div>
                                </div>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
        </section>

        <section id="products" class="marketplace-section" data-panel="products">
            <h2>Manage Products</h2>
            <p>Use this area to add, edit, or remove your product listings.</p>
        </section>

        <section id="cart" class="marketplace-section" data-panel="cart">
            <h2>Cart</h2>
            <p>Review the products you intend to purchase and prepare your checkout.</p>
        </section>

        <section id="orders" class="marketplace-section" data-panel="orders">
            <h2>Orders</h2>
            <p>Track your orders, review statuses, and manage shipments.</p>
        </section>
    </div>
{% endblock %}

{% block javascripts %}
<script>
    const tabs = document.querySelectorAll('.marketplace-tab');
    const panels = document.querySelectorAll('.marketplace-section');

    tabs.forEach(tab => {
        tab.addEventListener('click', () => {
            const target = tab.dataset.tab;

            tabs.forEach(item => item.classList.toggle('active', item === tab));
            panels.forEach(panel => panel.classList.toggle('show', panel.dataset.panel === target));
        });
    });
</script>
{% endblock %}
