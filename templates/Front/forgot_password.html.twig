<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password - AGRINOVA</title>
    <style>
        body { font-family: Arial, sans-serif; background:#f3f6f4; margin:0; }
        .wrap { max-width:460px; margin:48px auto; background:#fff; padding:24px; border-radius:14px; box-shadow:0 8px 28px rgba(0,0,0,.08); }
        h1 { margin:0 0 8px; color:#1a4d2e; font-size:24px; }
        p { margin:0 0 14px; color:#4b5563; }
        label { display:block; margin:12px 0 6px; font-weight:600; color:#111827; }
        input { width:100%; padding:11px; border:1px solid #d1d5db; border-radius:8px; }
        button { margin-top:14px; width:100%; background:#2d7a45; color:#fff; border:0; border-radius:8px; padding:11px; cursor:pointer; font-weight:700; }
        .alert { padding:10px; border-radius:8px; margin-bottom:10px; }
        .alert-error { background:#fef2f2; color:#991b1b; border:1px solid #fecaca; }
        .alert-success { background:#ecfdf5; color:#065f46; border:1px solid #a7f3d0; }
        .small { font-size:13px; color:#6b7280; margin-top:10px; }
    </style>
</head>
<body>
<div class="wrap">
    <h1>Recover account</h1>
    <p>Enter your email to receive a 6-digit reset code.</p>

    {% for flash in app.flashes('error') %}
        <div class="alert alert-error">{{ flash }}</div>
    {% endfor %}
    {% for flash in app.flashes('success') %}
        <div class="alert alert-success">{{ flash }}</div>
    {% endfor %}

    <form method="post" action="{{ path('app_forgot_password') }}">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('forgot_password') }}">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" required>

        <button type="submit">Send Reset Code</button>
    </form>

    <p class="small"><a href="{{ path('app_login') }}">Back to login</a></p>
</div>
</body>
</html>
