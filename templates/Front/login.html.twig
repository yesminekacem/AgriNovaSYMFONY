<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In – AGRINOVA</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@700;900&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --green-dark: #1a4d2e;
            --green-mid: #2d7a45;
            --green-light: #e8f5e0;
            --bg: #f0f5ee;
            --text-dark: #111;
            --text-mid: #555;
            --border: #dde8d8;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .container {
            width: 100%;
            max-width: 480px;
            display: flex;
            flex-direction: column;
            align-items: center;
            animation: fadeUp 0.5s ease both;
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Back link */
        .back-link {
            align-self: flex-start;
            display: inline-flex; align-items: center; gap: 6px;
            color: var(--text-mid); text-decoration: none;
            font-size: 0.9rem; font-weight: 500;
            margin-bottom: 2rem;
            transition: color 0.2s;
        }

        .back-link:hover { color: var(--green-mid); }

        .back-link svg {
            width: 16px; height: 16px;
            stroke: currentColor; fill: none;
            stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
        }

        /* Logo */
        .logo-wrap {
            width: 72px; height: 72px;
            background: var(--green-mid);
            border-radius: 22px;
            display: flex; align-items: center; justify-content: center;
            margin-bottom: 1.25rem;
            box-shadow: 0 8px 24px rgba(45,122,69,0.3);
        }

        .logo-wrap svg {
            width: 36px; height: 36px;
            fill: none; stroke: #fff;
            stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;
        }

        h1 {
            font-family: 'Fraunces', serif;
            font-size: 1.8rem; font-weight: 900;
            color: var(--text-dark); margin-bottom: 0.4rem;
        }

        .subtitle {
            color: var(--text-mid); font-size: 0.95rem;
            margin-bottom: 2rem;
        }

        /* Card */
        .card {
            width: 100%;
            background: #fff;
            border-radius: 20px;
            padding: 2.25rem 2.5rem;
            box-shadow: 0 4px 24px rgba(0,0,0,0.07);
        }

        /* Flash messages */
        .alert {
            padding: 0.85rem 1rem;
            border-radius: 10px;
            font-size: 0.9rem;
            margin-bottom: 1.25rem;
            font-weight: 500;
        }

        .alert-error {
            background: #fef2f2; color: #b91c1c;
            border: 1px solid #fecaca;
        }

        /* Form */
        .field { margin-bottom: 1.25rem; }

        label {
            display: block;
            font-size: 0.92rem; font-weight: 600;
            color: var(--text-dark); margin-bottom: 0.45rem;
        }

        input[type="email"],
        input[type="password"],
        input[type="text"] {
            width: 100%;
            padding: 0.8rem 1rem;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.95rem;
            color: var(--text-dark);
            background: var(--green-light);
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
        }

        input::placeholder { color: #aab8a5; }

        input:focus {
            border-color: var(--green-mid);
            box-shadow: 0 0 0 3px rgba(45,122,69,0.12);
            background: #fff;
        }

        .btn-submit {
            width: 100%;
            padding: 0.9rem;
            background: var(--green-mid);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 1rem; font-weight: 700;
            cursor: pointer;
            margin-top: 0.5rem;
            transition: background 0.2s, transform 0.15s;
        }

        .btn-submit:hover {
            background: var(--green-dark);
            transform: translateY(-1px);
        }

        .btn-submit:active { transform: translateY(0); }

        .card-footer {
            text-align: center;
            margin-top: 1.4rem;
            font-size: 0.9rem;
            color: var(--text-mid);
        }

        .card-footer a {
            color: var(--green-mid);
            font-weight: 600;
            text-decoration: none;
        }

        .card-footer a:hover { text-decoration: underline; }

        /* Face overlay styling */
        .face-overlay { display:none; position:fixed; inset:0; align-items:center; justify-content:center; background:rgba(0,0,0,0.5); z-index:12000 }
        .face-overlay.active { display:flex }
        .face-panel { background:#fff; padding:16px; border-radius:12px; max-width:480px; width:95%; box-shadow:0 10px 40px rgba(0,0,0,0.4); }
        .face-panel .face-video { width:100%; border-radius:8px; background:#000 }
        .face-panel .face-actions { margin-top:10px; display:flex; justify-content:flex-end; gap:8px }
        .face-panel .face-save-btn { background:var(--green-mid); color:#fff; border:none; padding:10px 12px; border-radius:8px; cursor:pointer }
        .face-panel .face-cancel-btn { background:#eee; border:none; padding:10px 12px; border-radius:8px; cursor:pointer }
    </style>
</head>
<body>

    <div class="container">

        <a href="{{ path('app_home') }}" class="back-link">
            <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
            Back to home
        </a>

        <!-- Logo -->
        <div class="logo-wrap">
            <!-- Leaf icon -->
            <svg viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z" stroke="none" fill="rgba(255,255,255,0.15)"/>
                <path d="M17 8c0 0-1.5 6-5 8s-7 1-7 1 1-4 4-6.5S17 8 17 8z"/>
                <path d="M7 17c2-2 5-5 5-9"/>
            </svg>
        </div>

        <h1>Welcome back</h1>
        <p class="subtitle">Sign in to your AGRINOVA account</p>

        <div class="card">

            {% if error %}
                <div class="alert alert-error">
                    {{ error.messageKey | trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {% for flash in app.flashes('error') %}
                <div class="alert alert-error">{{ flash }}</div>
            {% endfor %}

            <form method="post" action="{{ path('app_login') }}">

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="field">
                    <label for="email">Email</label>
                    <input
                        type="email"
                        id="email"
                        name="_username"
                        value="{{ last_username }}"
                        placeholder="you@example.com"
                        autocomplete="email"
                        required
                    >
                </div>

                <div class="field">
                    <label for="password">Password</label>
                    <input
                        type="password"
                        id="password"
                        name="_password"
                        placeholder="••••••••"
                        autocomplete="current-password"
                        required
                    >
                </div>

                <button type="submit" class="btn-submit">Sign In</button>

            </form>
<div class="card-footer">
    Don't have an account? <a href="{{ path('app_register') }}">Sign up</a>
</div>

            <div style="text-align:center;margin-top:12px">
                <button id="openFaceBtn" class="card-footer" type="button" style="background:none;border:none;color:var(--green-mid);cursor:pointer;font-weight:600">Or login with Face ID</button>
            </div>

        </div>

    </div>

    <!-- Face overlay (used for login detection) -->
    <div id="faceOverlay" class="face-overlay" aria-hidden="true">
        <div class="face-panel">
            <button id="faceCancelBtn" class="face-cancel-btn" style="float:right">✕</button>
            <h3 style="margin:0 0 10px">Face Login</h3>
            <div class="face-camera-widget" data-detect-url="{{ path('app_login_face_detect') }}" data-select-url="{{ path('app_login_face_select') }}">
                <form class="face-detect-form" action="{{ path('app_login_face_detect') }}" method="post">
                    <video class="face-video" autoplay playsinline></video>
                    <canvas class="face-canvas" style="display:none"></canvas>
                    <input type="hidden" name="face_image_base64" value="">
                    <div class="face-actions">
                        <button type="button" class="face-save-btn">Use Face</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="{{ asset('Front/js/face.js') }}"></script>
    <script>
        (function(){
            const openBtn = document.getElementById('openFaceBtn');
            const overlay = document.getElementById('faceOverlay');
            const cancel = document.getElementById('faceCancelBtn');
            const widget = overlay ? overlay.querySelector('.face-camera-widget') : null;

            function open(){
                if(!overlay || !widget) return;
                overlay.classList.add('active');
                // ensure widget is visible, then start detection
                try{
                    widget.style.display = 'block';
                    if(widget.__faceControls) widget.__faceControls.start({detect:true});
                    else {
                        // in case widget not yet initialized, wait a short time
                        setTimeout(()=>{ if(widget.__faceControls) widget.__faceControls.start({detect:true}); }, 200);
                    }
                }catch(e){console.error(e)}
            }
            function close(){
                if(!overlay || !widget) return;
                overlay.classList.remove('active');
                try{ if(widget.__faceControls) widget.__faceControls.stop(); }catch(e){}
            }

            if(openBtn) openBtn.addEventListener('click', open);
            if(cancel) cancel.addEventListener('click', close);
            if(overlay) overlay.addEventListener('click', function(e){ if(e.target===overlay) close(); });
        })();
    </script>

</body>
</html>
