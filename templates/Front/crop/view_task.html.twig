{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('Front/css/tasklist.css') }}">
{% endblock %}

{% block body %}
<div class="tasks-page">

    {# ── Header ── #}
    <div class="page-header">
        <div class="page-header-left">
            
            <h1>My Tasks</h1>
            
        </div>
    </div>

    {# ── Stats strip ── #}
    {% set total     = tasks|length %}
    {% set pending   = tasks|filter(t => t.status == 'pending')|length %}
    {% set inprog    = tasks|filter(t => t.status == 'in_progress')|length %}
    {% set completed = tasks|filter(t => t.status == 'completed')|length %}
    {% set overdue   = tasks|filter(t => t.status == 'overdue')|length %}

    <div class="stats-strip">
        <div class="stat-card">
            <span class="stat-label">Total</span>
            <span class="stat-value">{{ total }}</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">
                <span class="stat-dot" style="background:#f59e0b"></span>Pending
            </span>
            <span class="stat-value">{{ pending }}</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">
                <span class="stat-dot" style="background:#3b82f6"></span>In Progress
            </span>
            <span class="stat-value">{{ inprog }}</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">
                <span class="stat-dot" style="background:#2d9b5a"></span>Completed
            </span>
            <span class="stat-value">{{ completed }}</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">
                <span class="stat-dot" style="background:#ef4444"></span>Overdue
            </span>
            <span class="stat-value">{{ overdue }}</span>
        </div>
    </div>

    {# ── Controls bar ── #}
    <div class="controls-bar">
        <div class="search-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
            </svg>
            <input class="search-input" type="text" id="task-search" placeholder="Search tasks by name or description…">
        </div>

        <div class="filter-pills">
            <button class="pill active" data-filter="all">All</button>
            <button class="pill" data-filter="pending">Pending</button>
            <button class="pill" data-filter="in_progress">In Progress</button>
            <button class="pill" data-filter="completed">Completed</button>
            <button class="pill" data-filter="overdue">Overdue</button>
        </div>

        <select class="sort-select" id="task-sort">
            <option value="id-asc">Oldest first</option>
            <option value="id-desc">Newest first</option>
            <option value="name-asc">Name A–Z</option>
            <option value="status">By status</option>
        </select>
    </div>

    {# ── Task count ── #}
    <p class="tasks-count"><strong id="visible-count">{{ total }}</strong> task{{ total != 1 ? 's' : '' }}</p>

    {# ── Task grid ── #}
    <div class="tasks-grid" id="tasks-grid">

        {% for task in tasks %}
        <div class="task-card {{ task.status }}"
             data-status="{{ task.status }}"
             data-name="{{ task.taskName|lower }}"
             data-desc="{{ task.description|default('')|lower }}"
             data-id="{{ task.taskId }}">

            {# Top row: title + badge #}
            <div class="card-top">
                <h2>{{ task.taskName }}</h2>
                <span class="status-badge {{ task.status }}">
                    {{ task.status|replace({'_': ' '}) }}
                </span>
            </div>

            {# Description #}
            {% if task.description %}
            <p class="card-desc">{{ task.description }}</p>
            {% endif %}

            {# Meta chips #}
            <div class="card-meta">
                {% if task.crop.name is defined and task.crop.name %}
                <span class="meta-chip">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2a7 7 0 0 1 7 7c0 5-7 13-7 13S5 14 5 9a7 7 0 0 1 7-7z"/></svg>
                    {{ task.crop.name }}
                </span>
                {% endif %}

                {% if task.dueDate is defined and task.dueDate %}
                <span class="meta-chip">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2z"/></svg>
                    {{ task.dueDate|date('M d, Y') }}
                </span>
                {% endif %}

                {% if task.priority is defined and task.priority %}
                <span class="meta-chip priority-{{ task.priority|lower }}">
                    {{ task.priority }}
                </span>
                {% endif %}
            </div>

            {# Footer: ID + actions #}
            <div class="card-footer">
                <span class="task-id">#{{ task.taskId }}</span>
                <div class="card-actions">
                    <a href="{{ path('app_task_show', {'id': task.taskId}) }}" class="action-btn show">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5s8.268 2.943 9.542 7c-1.274 4.057-5.065 7-9.542 7s-8.268-2.943-9.542-7z"/></svg>
                        View
                    </a>
                    <a href="{{ path('app_task_edit', {'id': task.taskId}) }}" class="action-btn edit">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536M9 13l6.586-6.586a2 2 0 0 1 2.828 2.828L11.828 15.828a4 4 0 0 1-2.828 1.172H7v-2a4 4 0 0 1 1.172-2.828z"/></svg>
                        Edit
                    </a>
                   <form method="post"
      action="{{ path('app_task_delete', {'id': task.taskId}) }}"
      onsubmit="return confirm('Are you sure you want to delete this task?');"
      style="display:inline;">

    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ task.taskId) }}">

    <button type="submit" class="action-btn delete">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 7h12M9 7v12m6-12v12M10 3h4a1 1 0 0 1 1 1v2H9V4a1 1 0 0 1 1-1z"/>
        </svg>
        Delete
    </button>
</form>
                </div>
            </div>

        </div>
        {% else %}

        <div class="empty-state">
            <div class="empty-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2"/></svg>
            </div>
            <h3>No tasks yet</h3>
            <p>Add your first task to get started.</p>
        </div>

        {% endfor %}

    </div>{# /tasks-grid #}

</div>{# /tasks-page #}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('Front/js/tasklist.js') }}"></script>
{% endblock %}
