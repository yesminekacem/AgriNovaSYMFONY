{% extends 'base.html.twig' %}

{% block title %}{{ crop.name }} — View{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('Front/css/crop-chatbot.css') }}">
{% endblock %}

{% block body %}
{# Dynamic growth progress (use property directly) %}
<div style="max-width:900px;margin:0 auto;padding:1.5rem 1rem;font-family:var(--font-sans, sans-serif)">

  {# crop data for chatbot context #}
  <div id="crop-data" data-name="{{ crop.name }}" data-type="{{ crop.type }}" data-stage="{{ crop.growthStage }}" style="display:none"></div>

  <a class="btn btn-outline" href="{{ path('app_crop_index') }}" style="display:inline-flex;align-items:center;gap:6px;margin-bottom:1.5rem;">
    ← Back to crops
  </a>

  <div style="display:grid;grid-template-columns:300px minmax(0,1fr);gap:1.5rem;align-items:start">

    {# LEFT: Image + progress #}
    <div>
      <div style="border-radius:12px;overflow:hidden;border:0.5px solid #e5e7eb;background:#f9fafb;aspect-ratio:1/1;display:flex;align-items:center;justify-content:center;">
        {% if crop.imagePath %}
          <img src="{{ asset('cropsimages/' ~ crop.imagePath) }}" alt="{{ crop.name }}" style="width:100%;height:100%;object-fit:cover;">
        {% else %}
          <div style="font-size:72px;opacity:0.3">🌱</div>
        {% endif %}
      </div>

      <div style="margin-top:1rem;background:#fff;border:0.5px solid #e5e7eb;border-radius:12px;padding:1rem">
        <p style="font-size:12px;color:#6b7280;margin:0 0 8px;text-transform:uppercase;letter-spacing:0.05em">Growth progress</p>
        <div style="display:flex;justify-content:space-between;font-size:13px;color:#6b7280;margin-bottom:6px">
          <span>{{ crop.growthStage|capitalize }}</span>
          <span style="color:#111;font-weight:500">{{ crop.growthProgressPercent }}%</span>
        </div>
        <div style="height:6px;background:#f3f4f6;border-radius:99px;overflow:hidden">
          <div style="width:{{ crop.growthProgressPercent }}%;height:100%;background:#1D9E75;border-radius:99px"></div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:1rem">
          <div style="background:#f9fafb;border-radius:8px;padding:10px">
            <p style="font-size:11px;color:#6b7280;margin:0 0 2px">Status</p>
            <p style="font-size:13px;font-weight:500;color:#1D9E75;margin:0">{{ crop.status|capitalize }}</p>
          </div>
          <div style="background:#f9fafb;border-radius:8px;padding:10px">
            <p style="font-size:11px;color:#6b7280;margin:0 0 2px">Area</p>
            <p style="font-size:13px;font-weight:500;margin:0">{{ crop.areaSize ? crop.areaSize ~ ' ha' : 'N/A' }}</p>
          </div>
        </div>
      </div>
    </div>

    {# RIGHT: Info + diagnose #}
    <div>
      <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:1rem">
        <div>
          <h1 style="font-size:26px;font-weight:500;margin:0 0 4px">{{ crop.name }}</h1>
          <p style="font-size:14px;color:#6b7280;margin:0">{{ crop.type }} · {{ crop.variety }}</p>
        </div>
        <span style="font-size:12px;font-weight:500;background:#E1F5EE;color:#0F6E56;padding:4px 12px;border-radius:99px;white-space:nowrap">
          {{ crop.growthStage|capitalize }}
        </span>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:1.5rem">
        <div style="background:#fff;border:0.5px solid #e5e7eb;border-radius:12px;padding:1rem">
          <p style="font-size:11px;color:#6b7280;margin:0 0 4px;text-transform:uppercase;letter-spacing:0.05em">Planting date</p>
          <p style="font-size:15px;font-weight:500;margin:0">{{ crop.plantingDate ? crop.plantingDate|date('M d, Y') : 'N/A' }}</p>
        </div>
        <div style="background:#fff;border:0.5px solid #e5e7eb;border-radius:12px;padding:1rem">
          <p style="font-size:11px;color:#6b7280;margin:0 0 4px;text-transform:uppercase;letter-spacing:0.05em">Expected harvest</p>
          <p style="font-size:15px;font-weight:500;margin:0">{{ crop.expectedHarvestDate ? crop.expectedHarvestDate|date('M d, Y') : 'N/A' }}</p>
        </div>
      </div>

      {# Diagnose card #}
<div style="background:#fff;border:0.5px solid #e5e7eb;border-radius:12px;padding:1.25rem;margin-bottom:1.5rem">
  <p style="font-size:12px;color:#6b7280;margin:0 0 8px;text-transform:uppercase;letter-spacing:0.05em">Disease diagnosis</p>
  <p style="font-size:13px;color:#6b7280;margin:0 0 14px;line-height:1.6">Upload a photo of your crop to get an AI-powered disease diagnosis instantly.</p>

  <button type="button" id="diagnoseBtn"
    style="display:inline-flex;align-items:center;gap:8px;background:#1D9E75;color:#fff;border:none;border-radius:8px;padding:10px 20px;font-size:14px;font-weight:500;cursor:pointer;transition:background 0.15s"
    onmouseenter="this.style.background='#0F6E56'" onmouseleave="this.style.background='#1D9E75'">
    <span style="font-size:16px">📷</span> Diagnose Photo
  </button>

  <input type="file" id="diagnoseInput" accept="image/*" style="display:none">

  <div id="diagnoseResult" style="display:none;margin-top:16px"></div>
</div>

      {# Details table #}
      <div style="background:#fff;border:0.5px solid #e5e7eb;border-radius:12px;padding:1.25rem">
        <p style="font-size:12px;color:#6b7280;margin:0 0 12px;text-transform:uppercase;letter-spacing:0.05em">Details</p>
        <table style="width:100%;font-size:13px;border-collapse:collapse">
          <tr style="border-bottom:0.5px solid #f3f4f6">
            <td style="color:#6b7280;padding:8px 0">Type</td>
            <td style="text-align:right;font-weight:500;padding:8px 0">{{ crop.type }}</td>
          </tr>
          <tr style="border-bottom:0.5px solid #f3f4f6">
            <td style="color:#6b7280;padding:8px 0">Variety</td>
            <td style="text-align:right;font-weight:500;padding:8px 0">{{ crop.variety }}</td>
          </tr>
          <tr style="border-bottom:0.5px solid #f3f4f6">
            <td style="color:#6b7280;padding:8px 0">Growth stage</td>
            <td style="text-align:right;font-weight:500;padding:8px 0">{{ crop.growthStage|capitalize }}</td>
          </tr>
          <tr>
            <td style="color:#6b7280;padding:8px 0">Area size</td>
            <td style="text-align:right;font-weight:500;padding:8px 0">{{ crop.areaSize ? crop.areaSize ~ ' ha' : 'N/A' }}</td>
          </tr>
        </table>
      </div>
    </div>

  </div>
</div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="{{ asset('Front/js/diagnose.js') }}"></script>
  <script src="{{ asset('Front/js/crop-chatbot.js') }}"></script>
{% endblock %}