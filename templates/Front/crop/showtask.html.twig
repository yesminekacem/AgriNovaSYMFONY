{% extends 'base.html.twig' %}

{% block title %}Task — {{ task.taskName }}{% endblock %}
{% block page_title %}Task Detail{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  .task-detail-wrap {
    max-width: 640px;
    margin: 2rem auto;
    padding: 0 1rem;
    font-family: 'DM Sans', sans-serif;
  }

  /* Back link */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.82rem;
    font-weight: 500;
    color: #6b8f71;
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }
  .back-link:hover { color: #2d6a4f; }
  .back-link svg { width: 14px; height: 14px; }

  /* Card */
  .task-card {
    background: #fff;
    border-radius: 24px;
    border: 1px solid #e5ede8;
    box-shadow: 0 2px 30px rgba(0,0,0,0.06);
    overflow: hidden;
    animation: fadeUp 0.4s ease both;
  }

  /* Card top banner */
  .task-card-banner {
    background: linear-gradient(135deg, #2d6a4f 0%, #40916c 100%);
    padding: 2rem 2rem 1.5rem;
    position: relative;
    overflow: hidden;
  }
  .task-card-banner::after {
    content: '✅';
    position: absolute;
    right: 1.5rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 4rem;
    opacity: 0.15;
  }
  .task-card-banner h1 {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    color: #fff;
    line-height: 1.2;
    margin: 0;
  }
  .task-card-banner p {
    color: rgba(255,255,255,0.65);
    font-size: 0.8rem;
    margin-top: 4px;
    font-weight: 300;
  }

  /* Body */
  .task-card-body {
    padding: 1.75rem 2rem;
  }

  .detail-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.9rem 0;
    border-bottom: 1px solid #f0f4ee;
  }
  .detail-row:last-child { border-bottom: none; }

  .detail-label {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #9db8a3;
  }

  .detail-value {
    font-size: 0.9rem;
    color: #1a3a2a;
    font-weight: 500;
    text-align: right;
  }

  /* Status badge */
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 14px;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: capitalize;
    letter-spacing: 0.02em;
  }
  .status-badge .dot {
    width: 7px; height: 7px;
    border-radius: 50%;
  }
  .status-badge.completed  { background: #f0fdf4; color: #166534; }
  .status-badge.completed .dot  { background: #22c55e; }
  .status-badge.pending    { background: #fefce8; color: #854d0e; }
  .status-badge.pending .dot    { background: #eab308; }
  .status-badge.in_progress { background: #eff6ff; color: #1e40af; }
  .status-badge.in_progress .dot { background: #3b82f6; }
  .status-badge.cancelled  { background: #fef2f2; color: #991b1b; }
  .status-badge.cancelled .dot  { background: #ef4444; }

  /* Footer actions */
  .task-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 2rem;
    border-top: 1px solid #edf3ef;
    background: #fafcfb;
  }

  .btn-back {
    display: inline-flex; align-items: center; gap: 6px;
    background: none; border: 1.5px solid #ddeae1;
    color: #4a6e53; border-radius: 12px;
    padding: 10px 20px; font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem; font-weight: 500; cursor: pointer;
    text-decoration: none; transition: all 0.2s;
  }
  .btn-back:hover { background: #f0fdf4; border-color: #22c55e; color: #166534; }

  .btn-edit {
    display: inline-flex; align-items: center; gap: 6px;
    background: #2d6a4f; color: #fff; border: none;
    border-radius: 12px; padding: 10px 24px;
    font-family: 'Playfair Display', serif;
    font-size: 0.95rem; font-weight: 600; cursor: pointer;
    text-decoration: none; transition: all 0.2s;
    box-shadow: 0 4px 14px rgba(45,106,79,0.25);
  }
  .btn-edit:hover {
    background: #1b4332;
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(45,106,79,0.32);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
{% endblock %}

{% block body %}
<div class="task-detail-wrap">

  <a href="{{ path('app_task_index') }}" class="back-link">
    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to Tasks
  </a>

  <div class="task-card">

    <div class="task-card-banner">
      <h1>{{ task.taskName }}</h1>
      <p>Task details & status overview</p>
    </div>

    <div class="task-card-body">

      <div class="detail-row">
        <span class="detail-label">Status</span>
        <span class="status-badge {{ task.status|lower|replace({' ': '_'}) }}">
          <span class="dot"></span>
          {{ task.status }}
        </span>
      </div>

      {% if task.description is defined and task.description %}
      <div class="detail-row">
        <span class="detail-label">Description</span>
        <span class="detail-value" style="max-width:60%; word-break:break-word; text-align:right;">{{ task.description }}</span>
      </div>
      {% endif %}

      {% if task.scheduledDate is defined and task.scheduledDate %}
      <div class="detail-row">
        <span class="detail-label">Scheduled Date</span>
        <span class="detail-value">{{ task.scheduledDate|date('d M Y') }}</span>
      </div>
      {% endif %}

      {% if task.priority is defined and task.priority %}
      <div class="detail-row">
        <span class="detail-label">Priority</span>
        <span class="detail-value">{{ task.priority }}</span>
      </div>
      {% endif %}

      {% if task.assignedTo is defined and task.assignedTo %}
      <div class="detail-row">
        <span class="detail-label">Assigned To</span>
        <span class="detail-value">{{ task.assignedTo }}</span>
      </div>
      {% endif %}

    </div>

    <div class="task-card-footer">
      <a href="{{ path('app_task_index') }}" class="btn-back">
        ← All Tasks
      </a>
     
    </div>

  </div>

</div>
{% endblock %}
