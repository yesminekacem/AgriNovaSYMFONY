{# Hidden form submitted programmatically by the delete-confirm script #}
<form id="delete-form-task-{{ task.taskId }}" method="post" action="{{ path('app_task_delete', {'id': task.taskId}) }}" style="display:none;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ task.taskId) }}">
    <button type="submit">Delete</button>
</form>

<button type="button" class="btn js-delete-btn"
        data-target-form="delete-form-task-{{ task.taskId }}"
        data-title="Delete Task"
        data-message="Are you sure you want to delete this task? This action cannot be undone.">
    Delete
</button>

<link rel="stylesheet" href="{{ asset('Front/css/delete-confirm.css') }}">
<script src="{{ asset('Front/js/delete-confirm.js') }}"></script>