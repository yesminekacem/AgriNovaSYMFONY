{% extends 'base.html.twig' %}

{% block page_title %}Profile{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('Front/css/profile.css') }}">
{% endblock %}

{% block body %}
<div class="card" style="max-width:700px;margin:1rem auto;padding:1.5rem;border-radius:12px;background:#fff;">
    <h1>Your profile</h1>

    {% for flash in app.flashes('error') %}
        <div style="background:#fdecea;color:#b91c1c;padding:.6rem;border-radius:8px;margin-bottom:.8rem;">{{ flash }}</div>
    {% endfor %}
    {% for flash in app.flashes('success') %}
        <div style="background:#f0fdf4;color:#064e3b;padding:.6rem;border-radius:8px;margin-bottom:.8rem;">{{ flash }}</div>
    {% endfor %}

    <form method="post" action="{{ path('app_profile') }}" enctype="multipart/form-data" id="profile-form">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('profile_edit') }}">

        <div class="profile-top">
            <div class="avatar-wrap">
                {% if user.profileImage %}
                    <img class="avatar" id="avatarPreview" src="{{ asset('uploads/profile_images/' ~ user.profileImage) }}" alt="Profile image">
                {% else %}
                    <div class="avatar placeholder" id="avatarPreview">{{ user.email|first|upper }}</div>
                {% endif %}
            </div>

            <div class="avatar-upload">
                <label for="profile_image">Profile image</label>
                <input id="profile_image" name="profile_image" type="file" accept="image/*">
                <div class="hint">Allowed: JPG, PNG, GIF, WEBP — max 2MB.</div>
            </div>
        </div>

        <div class="field">
            <label for="fullName">Full name</label>
            <input id="fullName" name="fullName" type="text" value="{{ user.fullName }}">
        </div>

        <div class="field">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" required value="{{ user.email }}">
        </div>

        <div class="field">
            <label for="password">New password (leave blank to keep current)</label>
            <input id="password" name="password" type="password">
        </div>

        <div class="actions" style="display:flex;gap:.6rem;align-items:center">
            <button type="submit" class="btn">Save profile</button>
            <a href="{{ path('app_home') }}" style="margin-left:auto;color:#2d7a45;text-decoration:none;">Back home</a>
        </div>
    </form>

</div>
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('Front/js/profile.js') }}"></script>
{% endblock %}
