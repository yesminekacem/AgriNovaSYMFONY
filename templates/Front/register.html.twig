<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account – AGRINOVA</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@700;900&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --green-dark: #1a4d2e;
            --green-mid: #2d7a45;
            --green-light: #e8f5e0;
            --bg: #f0f5ee;
            --text-dark: #111;
            --text-mid: #555;
            --border: #dde8d8;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .container {
            width: 100%;
            max-width: 480px;
            display: flex;
            flex-direction: column;
            align-items: center;
            animation: fadeUp 0.5s ease both;
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .back-link {
            align-self: flex-start;
            display: inline-flex; align-items: center; gap: 6px;
            color: var(--text-mid); text-decoration: none;
            font-size: 0.9rem; font-weight: 500;
            margin-bottom: 2rem;
            transition: color 0.2s;
        }

        .back-link:hover { color: var(--green-mid); }

        .back-link svg {
            width: 16px; height: 16px;
            stroke: currentColor; fill: none;
            stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
        }

        .logo-wrap {
            width: 72px; height: 72px;
            background: var(--green-mid);
            border-radius: 22px;
            display: flex; align-items: center; justify-content: center;
            margin-bottom: 1.25rem;
            box-shadow: 0 8px 24px rgba(45,122,69,0.3);
        }

        .logo-wrap svg {
            width: 36px; height: 36px;
            fill: none; stroke: #fff;
            stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;
        }

        h1 {
            font-family: 'Fraunces', serif;
            font-size: 1.8rem; font-weight: 900;
            color: var(--text-dark); margin-bottom: 0.4rem;
        }

        .subtitle {
            color: var(--text-mid); font-size: 0.95rem;
            margin-bottom: 2rem;
        }

        .card {
            width: 100%;
            background: #fff;
            border-radius: 20px;
            padding: 2.25rem 2.5rem;
            box-shadow: 0 4px 24px rgba(0,0,0,0.07);
        }

        .alert {
            padding: 0.85rem 1rem;
            border-radius: 10px;
            font-size: 0.9rem;
            margin-bottom: 1.25rem;
            font-weight: 500;
        }

        .alert-error {
            background: #fef2f2; color: #b91c1c;
            border: 1px solid #fecaca;
        }

        .alert-success {
            background: #f0fdf4; color: #15803d;
            border: 1px solid #bbf7d0;
        }

        .field { margin-bottom: 1.25rem; }

        label {
            display: block;
            font-size: 0.92rem; font-weight: 600;
            color: var(--text-dark); margin-bottom: 0.45rem;
        }

        input[type="text"],
        input[type="email"],
        input[type="password"] {
            width: 100%;
            padding: 0.8rem 1rem;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.95rem;
            color: var(--text-dark);
            background: var(--green-light);
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
        }

        input::placeholder { color: #aab8a5; }

        input:focus {
            border-color: var(--green-mid);
            box-shadow: 0 0 0 3px rgba(45,122,69,0.12);
            background: #fff;
        }

        .field-error {
            font-size: 0.82rem; color: #b91c1c;
            margin-top: 0.35rem;
        }

        .btn-submit {
            width: 100%;
            padding: 0.9rem;
            background: var(--green-mid);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 1rem; font-weight: 700;
            cursor: pointer;
            margin-top: 0.5rem;
            transition: background 0.2s, transform 0.15s;
        }

        .btn-submit:hover {
            background: var(--green-dark);
            transform: translateY(-1px);
        }

        .btn-submit:active { transform: translateY(0); }

        .card-footer {
            text-align: center;
            margin-top: 1.4rem;
            font-size: 0.9rem;
            color: var(--text-mid);
        }

        .card-footer a {
            color: var(--green-mid);
            font-weight: 600;
            text-decoration: none;
        }

        .card-footer a:hover { text-decoration: underline; }
    </style>
</head>
<body>

    <div class="container">

        <a href="{{ path('app_home') }}" class="back-link">
            <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
            Back to home
        </a>

        <div class="logo-wrap">
            <svg viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z" stroke="none" fill="rgba(255,255,255,0.15)"/>
                <path d="M17 8c0 0-1.5 6-5 8s-7 1-7 1 1-4 4-6.5S17 8 17 8z"/>
                <path d="M7 17c2-2 5-5 5-9"/>
            </svg>
        </div>

        <h1>Create your account</h1>
        <p class="subtitle">Join AGRINOVA and start farming smarter</p>

        <div class="card">

            {% for flash in app.flashes('error') %}
                <div class="alert alert-error">{{ flash }}</div>
            {% endfor %}

            {% for flash in app.flashes('success') %}
                <div class="alert alert-success">{{ flash }}</div>
            {% endfor %}

          <form method="post" action="{{ path('app_register') }}">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token('register') }}">
    <div class="field">
        <label for="fullName">Full Name</label>
        <input
            type="text"
            id="fullName"
            name="fullName"
            placeholder="Juan Dela Cruz"
            required
        >
    </div>

    <div class="field">
        <label for="email">Email</label>
        <input
            type="email"
            id="email"
            name="email"
            placeholder="you@example.com"
            required
        >
    </div>

    <div class="field">
        <label for="password">Password</label>
        <input
            type="password"
            id="password"
            name="password"
            placeholder="••••••••"
            required
        >
    </div>

    <button type="submit" class="btn-submit">Create Account</button>
</form>

            <div class="card-footer">
                Already have an account? <a href="{{ path('app_login') }}">Sign in</a>
            </div>

        </div>

    </div>

</body>
</html>
