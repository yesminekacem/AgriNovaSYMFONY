{% extends base_template|default('base.html.twig') %}
{% form_theme form 'form/inventory_theme.html.twig' %}

{% block title %}{{ pageHeading }}{% endblock %}
{% block page_title %}Inventory Form{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .inventory-shell { display: grid; gap: 1.5rem; }
        .inventory-toolbar,
        .inventory-card {
            background: #fff;
            border: 1px solid #dce9df;
            border-radius: 1.25rem;
            box-shadow: 0 14px 32px rgba(20, 83, 45, 0.08);
        }
        .inventory-toolbar { padding: 1.25rem 1.5rem; }
        .inventory-card { padding: 1.5rem; }
        .inventory-grid { display: grid; gap: 1rem; grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .inventory-field,
        .inventory-checkbox-row { display: flex; flex-direction: column; gap: 0.45rem; }
        .inventory-label {
            color: #14532d;
            font-size: 0.88rem;
            font-weight: 700;
            letter-spacing: 0.01em;
        }
        .inventory-input {
            width: 100%;
            border: 1px solid #cfe0d3;
            border-radius: 0.95rem;
            background: #f8fcf9;
            padding: 0.85rem 1rem;
            color: #1f2937;
            transition: border-color .15s, box-shadow .15s;
        }
        .inventory-input:focus {
            border-color: #22c55e;
            box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.14);
            outline: none;
        }
        .inventory-textarea { min-height: 7rem; resize: vertical; }
        .inventory-errors {
            margin: 0;
            padding-left: 1rem;
            color: #b91c1c;
            font-size: 0.82rem;
        }
        .inventory-summary {
            border: 1px solid #fecaca;
            border-radius: 1rem;
            background: #fef2f2;
            padding: 1rem 1.25rem;
        }
        .inventory-checkbox-label {
            display: inline-flex;
            align-items: center;
            gap: 0.7rem;
            font-weight: 600;
            color: #14532d;
        }
        .inventory-checkbox-label input { accent-color: #166534; }
        @media (max-width: 900px) {
            .inventory-grid { grid-template-columns: 1fr; }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="inventory-shell">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="rounded-2xl border px-4 py-3 text-sm font-medium {{ label == 'success' ? 'border-green-200 bg-green-50 text-green-700' : 'border-red-200 bg-red-50 text-red-700' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <section class="inventory-toolbar flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
            <div>
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-green-700">Inventory Module</p>
                <h1 class="mt-2 text-3xl font-bold text-slate-900">{{ pageHeading }}</h1>
                <p class="mt-2 max-w-2xl text-sm text-slate-500">
                    Keep the form clean and validated before it reaches the shared `agrinova.inventory` table.
                </p>
            </div>
            <div class="flex flex-wrap gap-3">
                <a href="{{ path('inventory_index') }}" class="inline-flex items-center rounded-xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
                    Back to inventory
                </a>
                {% if item.id %}
                    <a href="{{ path('inventory_show', {id: item.id}) }}" class="inline-flex items-center rounded-xl bg-green-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-green-800">
                        View item
                    </a>
                {% endif %}
            </div>
        </section>

        <section class="inventory-card">
            {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
                {% if form.vars.submitted and not form.vars.valid %}
                    <div class="inventory-summary mb-6">
                        <h2 class="text-base font-semibold text-red-700">Some fields still need your attention.</h2>
                        <p class="mt-1 text-sm text-red-600">Please check the fields below before saving.</p>
                        <ul class="mt-3 list-disc space-y-1 pl-5 text-sm text-red-700">
                            {% for error in form.vars.errors %}
                                <li>{{ error.message }}</li>
                            {% endfor %}
                            {% for child in form %}
                                {% for error in child.vars.errors %}
                                    <li><span class="font-semibold">{{ child.vars.label|default(child.vars.name) }}</span>: {{ error.message }}</li>
                                {% endfor %}
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}

                <div class="inventory-grid">
                    {{ form_row(form.itemName) }}
                    {{ form_row(form.itemType) }}
                    {{ form_row(form.conditionStatus) }}
                    {{ form_row(form.quantity) }}
                    {{ form_row(form.unitPrice) }}
                    {{ form_row(form.purchaseDate) }}
                    {{ form_row(form.ownerName) }}
                    {{ form_row(form.ownerContact) }}
                    <div class="md:col-span-2">{{ form_row(form.description) }}</div>
                    {{ form_row(form.isRentable) }}
                    {{ form_row(form.rentalPricePerDay) }}
                    {{ form_row(form.rentalStatus) }}
                    {{ form_row(form.totalUsageHours) }}
                    {{ form_row(form.lastMaintenanceDate) }}
                    {{ form_row(form.nextMaintenanceDate) }}
                    {{ form_row(form.imagePath) }}
                </div>

                {{ form_rest(form) }}

                <div class="mt-8 flex flex-wrap gap-3">
                    <button class="inline-flex items-center rounded-xl bg-green-700 px-5 py-3 text-sm font-semibold text-white transition hover:bg-green-800">
                        {{ submitLabel }}
                    </button>
                    <a href="{{ path('inventory_index') }}" class="inline-flex items-center rounded-xl border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
                        Cancel
                    </a>
                </div>
            {{ form_end(form) }}
        </section>
    </div>
{% endblock %}
