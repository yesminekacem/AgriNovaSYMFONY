{% extends base_template|default('base.html.twig') %}

{% block title %}Print QR Label - {{ item.itemName }}{% endblock %}

{% block stylesheets %}
<style>
    @media print {
        body * {
            visibility: hidden;
        }
        .qr-print-area, .qr-print-area * {
            visibility: visible;
        }
        .qr-print-area {
            position: absolute;
            left: 50%;
            top: 50%;
            transform: translate(-50%, -50%);
        }
        .no-print {
            display: none;
        }
    }
    
    .qr-container {
        max-width: 400px;
        margin: 40px auto;
        text-align: center;
    }
    
    .qr-card {
        background: white;
        border: 2px solid #e5e7eb;
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    }
    
    .qr-image {
        width: 250px;
        height: 250px;
        margin: 20px auto;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .qr-image svg {
        width: 100% !important;
        height: 100% !important;
        display: block;
    }
    
    .item-info {
        margin-top: 20px;
        padding-top: 20px;
        border-top: 1px solid #e5e7eb;
    }
    
    .item-name {
        font-size: 1.5em;
        font-weight: bold;
        color: #1f2937;
        margin-bottom: 8px;
    }
    
    .item-meta {
        color: #6b7280;
        font-size: 0.9em;
        margin-bottom: 5px;
    }
    
    .status-badge {
        display: inline-block;
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 0.85em;
        font-weight: 600;
        text-transform: uppercase;
        margin-top: 10px;
    }
    
    .status-available { background: #dcfce7; color: #166534; }
    .status-rented_out { background: #fef3c7; color: #92400e; }
    .status-maintenance { background: #fee2e2; color: #991b1b; }
    .status-retired { background: #e5e7eb; color: #374151; }
    
    .actions {
        margin-top: 30px;
        display: flex;
        gap: 10px;
        justify-content: center;
    }
    
    .btn {
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 500;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        border: none;
    }
    
    .btn-primary {
        background: #22c55e;
        color: white;
    }
    
    .btn-outline {
        background: white;
        color: #374151;
        border: 1px solid #d1d5db;
    }
    
    .company-brand {
        margin-bottom: 20px;
    }
    
    .company-brand h2 {
        color: #22c55e;
        font-size: 1.8em;
        margin: 0;
    }
    
    .company-brand p {
        color: #6b7280;
        margin: 5px 0 0 0;
    }
</style>
{% endblock %}

{% block body %}
<div class="qr-container qr-print-area">
    <div class="qr-card">
        <div class="company-brand">
            <h2>AGRINOVA</h2>
            <p>Smart Farm Platform</p>
        </div>
        
        <div class="qr-image">{{ qrSvg|raw }}</div>
        
        <div class="item-info">
            <div class="item-name">{{ item.itemName }}</div>
            <div class="item-meta">Type: {{ item.itemType }}</div>
            <div class="item-meta">ID: #{{ item.id }}</div>
            {% if item.ownerName %}
                <div class="item-meta">Owner: {{ item.ownerName }}</div>
            {% endif %}
            <span class="status-badge status-{{ item.rentalStatus|lower }}">
                {{ item.rentalStatus|replace({'_': ' '}) }}
            </span>
        </div>
    </div>
    
    <div class="actions no-print">
        <button onclick="window.print()" class="btn btn-primary">
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
            </svg>
            Print Label
        </button>
        <a href="{{ path('inventory_show', {id: item.id}) }}" class="btn btn-outline">
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            Back to Item
        </a>
    </div>
</div>
{% endblock %}
