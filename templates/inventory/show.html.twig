{% extends base_template|default('base.html.twig') %}

{% block title %}{{ item.itemName }}{% endblock %}
{% block page_title %}Inventory Details{% endblock %}

{% block body %}
    <div class="space-y-6">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="rounded-2xl border px-4 py-3 text-sm font-medium {{ label == 'success' ? 'border-green-200 bg-green-50 text-green-700' : 'border-red-200 bg-red-50 text-red-700' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-[0_14px_32px_rgba(20,83,45,0.08)]">
            <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
                <div>
                    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-green-700">Inventory Item</p>
                    <h1 class="mt-2 text-3xl font-bold text-slate-900">{{ item.itemName }}</h1>
                    <p class="mt-2 max-w-2xl text-sm text-slate-500">
                        {{ item.description ?: 'No description was provided for this inventory item.' }}
                    </p>
                </div>
                {% set isInventoryOwner = is_granted('ROLE_ADMIN') or (app.user and item.ownerContact is not empty and item.ownerContact|lower == app.user.email|lower) or (app.user and item.owner and item.owner.id == app.user.id) %}
                <div class="flex flex-wrap gap-3">
                    <a href="{{ path('inventory_index') }}" class="inline-flex items-center rounded-xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
                        Back to list
                    </a>
                    {% if item.isRentable %}
                        <a href="{{ path('rental_index', {inventory: item.id}) }}" class="inline-flex items-center rounded-xl border border-blue-200 bg-blue-50 px-4 py-2 text-sm font-semibold text-blue-700 transition hover:bg-blue-100">
                            View rentals
                        </a>
                    {% endif %}
                    {% if item.isRentable and item.rentalStatus not in ['RENTED_OUT', 'IN_USE', 'MAINTENANCE', 'RETIRED'] %}
                        <a href="{{ path('rental_new', {inventory: item.id}) }}" class="inline-flex items-center rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-2 text-sm font-semibold text-emerald-700 transition hover:bg-emerald-100">
                            Create rental
                        </a>
                    {% endif %}
                    <a href="{{ path('qrcode_inventory_print', {id: item.id}) }}" class="inline-flex items-center rounded-xl border border-purple-200 bg-purple-50 px-4 py-2 text-sm font-semibold text-purple-700 transition hover:bg-purple-100" target="_blank">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4h2v-4zM6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                        QR Code
                    </a>
                    <button form="inventory-weather-form" class="inline-flex items-center rounded-xl border border-sky-200 bg-sky-50 px-4 py-2 text-sm font-semibold text-sky-700 transition hover:bg-sky-100">
                        Weather API
                    </button>
                    {% if loadWeather %}
                        <a href="{{ path('inventory_show', {id: item.id}) }}" class="inline-flex items-center rounded-xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
                            Reset API
                        </a>
                    {% endif %}
                    {% if isInventoryOwner %}
                        <a href="{{ path('inventory_edit', {id: item.id}) }}" class="inline-flex items-center rounded-xl bg-green-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-green-800">
                            Edit item
                        </a>
                        {{ include('inventory/_delete_form.html.twig', {item: item}) }}
                    {% endif %}
                </div>
            </div>
        </section>

        <section class="grid gap-6 lg:grid-cols-3">
            <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-[0_14px_32px_rgba(20,83,45,0.08)] lg:col-span-2">
                <h2 class="text-lg font-bold text-slate-900">Core details</h2>
                <dl class="mt-5 grid gap-5 sm:grid-cols-2">
                    <div>
                        <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Item type</dt>
                        <dd class="mt-2 text-sm font-semibold text-slate-900">{{ item.itemType }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Condition</dt>
                        <dd class="mt-2 text-sm font-semibold text-slate-900">{{ item.conditionStatus }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Quantity</dt>
                        <dd class="mt-2 text-sm font-semibold text-slate-900">{{ item.quantity }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Unit price</dt>
                        <dd class="mt-2 text-sm font-semibold text-slate-900">{{ item.unitPrice|number_format(2, '.', ',') }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Purchase date</dt>
                        <dd class="mt-2 text-sm font-semibold text-slate-900">{{ item.purchaseDate ? item.purchaseDate|date('d M Y') : 'Not provided' }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Stock value</dt>
                        <dd class="mt-2 text-sm font-semibold text-slate-900">{{ item.estimatedValue|number_format(2, '.', ',') }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Owner name</dt>
                        <dd class="mt-2 text-sm font-semibold text-slate-900">{{ item.ownerName ?: 'Not provided' }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Owner contact</dt>
                        <dd class="mt-2 text-sm font-semibold text-slate-900">{{ item.ownerContact ?: 'Not provided' }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Usage hours</dt>
                        <dd class="mt-2 text-sm font-semibold text-slate-900">{{ item.totalUsageHours ?? 0 }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Image path</dt>
                        <dd class="mt-2 break-all text-sm font-semibold text-slate-900">{{ item.imagePath ?: 'Not provided' }}</dd>
                    </div>
                </dl>
            </article>

            <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-[0_14px_32px_rgba(20,83,45,0.08)]">
                <h2 class="text-lg font-bold text-slate-900">Rental & maintenance</h2>
                <dl class="mt-5 space-y-5">
                    <div>
                        <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Rentable</dt>
                        <dd class="mt-2 text-sm font-semibold text-slate-900">{{ item.isRentable ? 'Yes' : 'No' }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Rental status</dt>
                        <dd class="mt-2 text-sm font-semibold text-slate-900">{{ item.rentalStatus }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Rental price / day</dt>
                        <dd class="mt-2 text-sm font-semibold text-slate-900">{{ item.rentalPricePerDay|default(0)|number_format(2, '.', ',') }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Last maintenance</dt>
                        <dd class="mt-2 text-sm font-semibold text-slate-900">{{ item.lastMaintenanceDate ? item.lastMaintenanceDate|date('d M Y') : 'Not provided' }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Next maintenance</dt>
                        <dd class="mt-2 text-sm font-semibold text-slate-900">{{ item.nextMaintenanceDate ? item.nextMaintenanceDate|date('d M Y') : 'Not planned' }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Created at</dt>
                        <dd class="mt-2 text-sm font-semibold text-slate-900">{{ item.createdAt ? item.createdAt|date('d M Y H:i') : 'Unknown' }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Last updated</dt>
                        <dd class="mt-2 text-sm font-semibold text-slate-900">{{ item.updatedAt ? item.updatedAt|date('d M Y H:i') : 'Unknown' }}</dd>
                    </div>
                </dl>
            </article>
        </section>

        <section class="grid gap-6 xl:grid-cols-[minmax(0,1.2fr)_minmax(360px,1fr)]">
            <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-[0_14px_32px_rgba(20,83,45,0.08)]">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
                    <div>
                        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-green-700">Inventory API</p>
                        <h2 class="mt-2 text-2xl font-bold text-slate-900">Maintenance weather lookup</h2>
                        <p class="mt-2 max-w-2xl text-sm text-slate-500">
                            Check a city before scheduling outdoor maintenance, transport, or stock movement.
                        </p>
                    </div>
                </div>

                <form id="inventory-weather-form" method="get" class="mt-6 flex flex-col gap-3 sm:flex-row">
                    <input
                        type="text"
                        name="weatherCity"
                        value="{{ weatherCity|default('') }}"
                        placeholder="Enter a city or farm area"
                        class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700 outline-none transition focus:border-green-500 focus:ring-4 focus:ring-green-100"
                    >
                    <input type="hidden" name="loadWeather" value="1">
                </form>

                {% if loadWeather and weatherCity is not empty and maintenanceWeather is null %}
                    <div class="mt-5 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-700">
                        No weather result was found for this location. Try a clearer city or region name.
                    </div>
                {% elseif not loadWeather %}
                    <div class="mt-5 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-600">
                        Enter a city and click <strong>Load Weather API</strong> to fetch live outdoor conditions for maintenance planning.
                    </div>
                {% endif %}

                {% if maintenanceWeather %}
                    <div class="mt-6 space-y-5">
                        <div class="rounded-2xl border border-blue-100 bg-blue-50 p-4">
                            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-blue-700">Resolved location</p>
                            <p class="mt-2 text-lg font-bold text-slate-900">
                                {{ maintenanceWeather.location.name }}{% if maintenanceWeather.location.admin1 %}, {{ maintenanceWeather.location.admin1 }}{% endif %}{% if maintenanceWeather.location.country %}, {{ maintenanceWeather.location.country }}{% endif %}
                            </p>
                            <p class="mt-2 text-sm text-slate-600">
                                Current: {{ maintenanceWeather.current.temperature ?? 'N/A' }}°C, rain {{ maintenanceWeather.current.precipitation ?? 0 }} mm, wind {{ maintenanceWeather.current.wind ?? 'N/A' }} km/h
                            </p>
                        </div>

                        <div class="grid gap-4 md:grid-cols-3">
                            {% for day in maintenanceWeather.days %}
                                {% set riskClass = day.risk == 'High' ? 'border-red-200 bg-red-50 text-red-700' : (day.risk == 'Moderate' ? 'border-amber-200 bg-amber-50 text-amber-700' : 'border-emerald-200 bg-emerald-50 text-emerald-700') %}
                                <div class="rounded-2xl border p-4 {{ riskClass }}">
                                    <p class="text-xs font-semibold uppercase tracking-[0.14em]">{{ day.date|date('D d M') }}</p>
                                    <p class="mt-3 text-lg font-bold">{{ day.tempMax ?? 'N/A' }}° / {{ day.tempMin ?? 'N/A' }}°</p>
                                    <p class="mt-2 text-sm">Rain: {{ day.rainMm ?? 0 }} mm</p>
                                    <p class="mt-1 text-sm">Rain chance: {{ day.rainProbability ?? 0 }}%</p>
                                    <p class="mt-1 text-sm">Wind max: {{ day.windMax ?? 'N/A' }} km/h</p>
                                    <p class="mt-3 text-sm font-semibold">Outdoor risk: {{ day.risk }}</p>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
            </article>

            <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-[0_14px_32px_rgba(20,83,45,0.08)]">
                <h2 class="text-lg font-bold text-slate-900">Why this is safe</h2>
                <div class="mt-5 space-y-4 text-sm text-slate-600">
                    <p>This feature uses read-only weather data and does not write anything to your database.</p>
                    <p>If the API is unavailable, the inventory page still works normally and simply hides the forecast block.</p>
                    <p>It is useful for deciding whether maintenance, movement, or restocking should happen outdoors in the next few days.</p>
                </div>
            </article>
        </section>
    </div>
{% endblock %}
