{% extends 'base.html.twig' %}

{% block title %}Cart - AgriNova{% endblock %}
{% block page_title %}Your Cart{% endblock %}

{% block body %}
<section class="mx-auto max-w-6xl p-6">
    {% include 'product/_marketplace_nav.html.twig' %}

    <div class="mb-8">
        <h1 class="text-3xl font-semibold text-slate-900">Your Cart</h1>
        <p class="mt-2 text-sm text-slate-600">Review your selected items before proceeding to checkout</p>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 rounded-lg p-4 {% if label == 'success' %}bg-green-100 text-green-800{% else %}bg-red-100 text-red-800{% endif %}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {% if cart_items is empty %}
        <div class="rounded-3xl border border-slate-200 bg-white p-12 text-center">
            <div class="mb-4 text-4xl">🛒</div>
            <h3 class="text-lg font-semibold text-slate-900">Your cart is empty</h3>
            <p class="mt-2 text-sm text-slate-600">Looks like you haven't added anything to your cart yet.</p>
            <a href="{{ path('product_marketplace') }}" class="mt-6 inline-block rounded-lg bg-green-600 px-6 py-2 text-sm font-semibold text-white transition hover:bg-green-700">
                Browse Marketplace
            </a>
        </div>
    {% else %}
        <div class="rounded-xl border border-slate-200 bg-white overflow-hidden shadow">
            <table class="min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-50">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Product</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Price (TND/kg)</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Quantity (kg)</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Total</th>
                        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-slate-200">
                    {% set cart_total = 0 %}
                    {% for item in cart_items %}
                        {% set product = item.product %}
                        {% set item_total = product.pricePerUnit * item.quantity %}
                        {% set cart_total = cart_total + item_total %}
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center">
                                    <div class="h-10 w-10 flex-shrink-0 bg-slate-100 rounded flex items-center justify-center overflow-hidden">
                                        {% if product.picture %}
                                            <img class="h-10 w-10 object-cover" src="/uploads/products/{{ product.picture }}" alt="">
                                        {% else %}
                                            <span class="text-lg">🌾</span>
                                        {% endif %}
                                    </div>
                                    <div class="ml-4">
                                        <div class="text-sm font-medium text-slate-900">{{ product.productName }}</div>
                                        <div class="text-sm text-slate-500">{{ product.category }}</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                                {{ product.pricePerUnit }}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                                {{ item.quantity }}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-900 font-medium">
                                {{ item_total }}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <a href="{{ path('cart_remove', {'id': item.id}) }}" class="text-red-600 hover:text-red-900 bg-red-50 hover:bg-red-100 px-3 py-1 rounded-md transition" onclick="return confirm('Remove this item from your cart?');">Remove</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            
            <div class="bg-slate-50 px-6 py-4 border-t border-slate-200 flex justify-between items-center">
                <div class="text-lg font-semibold text-slate-900">
                    Total: {{ cart_total }} TND
                </div>
                <button class="rounded-lg bg-green-600 px-6 py-2 text-sm font-semibold text-white transition hover:bg-green-700">
                    Proceed to Checkout
                </button>
            </div>
        </div>
    {% endif %}
</section>
{% endblock %}
