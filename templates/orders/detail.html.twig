{% extends 'base.html.twig' %}

{% block title %}Order #{{ order.id }} - AgriNova{% endblock %}
{% block page_title %}Order Details{% endblock %}

{% block body %}
<section class="mx-auto max-w-6xl p-6">
    {% include 'product/_marketplace_nav.html.twig' %}

    <div class="mb-8">
        <a href="{{ path('orders_index') }}" class="text-green-600 hover:text-green-700 text-sm font-medium mb-4 inline-flex items-center">
            ← Back to Orders
        </a>
        <h1 class="text-3xl font-semibold text-slate-900">Order #{{ order.id }}</h1>
        <p class="mt-2 text-sm text-slate-600">Placed on {{ order.orderDate|date('d M Y, H:i') }}</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Order Items -->
        <div class="lg:col-span-2">
            <div class="rounded-xl border border-slate-200 bg-white overflow-hidden shadow">
                <div class="bg-slate-50 px-6 py-4 border-b border-slate-200">
                    <h2 class="text-lg font-semibold text-slate-900">Order Items</h2>
                </div>
                
                <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-50">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Product</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Price</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Quantity</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-slate-200">
                        {% for item in order.orderItems %}
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="h-10 w-10 flex-shrink-0 bg-slate-100 rounded flex items-center justify-center overflow-hidden">
                                            {% if item.product.picture %}
                                                <img class="h-10 w-10 object-cover" src="/uploads/products/{{ item.product.picture }}" alt="">
                                            {% else %}
                                                <span class="text-lg">🌾</span>
                                            {% endif %}
                                        </div>
                                        <div class="ml-4">
                                            <div class="text-sm font-medium text-slate-900">{{ item.productName }}</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-900">
                                    {{ item.pricePerUnit }} TND
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-900">
                                    {{ item.quantity }} kg
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-900">
                                    {{ item.subtotal }} TND
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
                
                <div class="bg-slate-50 px-6 py-4 border-t border-slate-200">
                    <div class="flex justify-between items-center text-lg font-semibold text-slate-900">
                        <span>Total:</span>
                        <span>{{ order.totalPrice }} TND</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Order Information -->
        <div class="lg:col-span-1">
            <div class="rounded-xl border border-slate-200 bg-white overflow-hidden shadow">
                <div class="bg-slate-50 px-6 py-4 border-b border-slate-200">
                    <h2 class="text-lg font-semibold text-slate-900">Order Information</h2>
                </div>
                
                <div class="p-6 space-y-6">
                    <!-- Status -->
                    <div>
                        <p class="text-xs text-slate-600 uppercase tracking-wider font-semibold">Status</p>
                        <div class="mt-2 inline-flex items-center px-3 py-1 rounded-full text-sm font-medium
                            {% if order.status == 'Pending' %}
                                bg-yellow-100 text-yellow-800
                            {% elseif order.status == 'Confirmed' %}
                                bg-blue-100 text-blue-800
                            {% elseif order.status == 'Shipped' %}
                                bg-purple-100 text-purple-800
                            {% elseif order.status == 'Delivered' %}
                                bg-green-100 text-green-800
                            {% elseif order.status == 'Cancelled' %}
                                bg-red-100 text-red-800
                            {% else %}
                                bg-slate-100 text-slate-800
                            {% endif %}
                        ">
                            {{ order.status }}
                        </div>
                    </div>

                    <!-- Order Date -->
                    <div>
                        <p class="text-xs text-slate-600 uppercase tracking-wider font-semibold">Order Date</p>
                        <p class="mt-2 text-sm text-slate-900">{{ order.orderDate|date('d M Y, H:i') }}</p>
                    </div>

                    <!-- Payment Method -->
                    <div>
                        <p class="text-xs text-slate-600 uppercase tracking-wider font-semibold">Payment Method</p>
                        <p class="mt-2 text-sm text-slate-900">
                            {% if order.paymentMethod == 'cash_on_delivery' %}
                                Cash on Delivery
                            {% elseif order.paymentMethod == 'paypal' %}
                                PayPal
                            {% else %}
                                {{ order.paymentMethod }}
                            {% endif %}
                        </p>
                    </div>

                    <!-- Delivery Address -->
                    <div>
                        <p class="text-xs text-slate-600 uppercase tracking-wider font-semibold">Delivery Address</p>
                        <p class="mt-2 text-sm text-slate-900 whitespace-pre-wrap">{{ order.deliveryAddress }}</p>
                    </div>

                    <!-- Total Amount -->
                    <div class="pt-4 border-t border-slate-200">
                        <p class="text-xs text-slate-600 uppercase tracking-wider font-semibold">Total Amount</p>
                        <p class="mt-2 text-2xl font-bold text-green-600">{{ order.totalPrice }} TND</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
